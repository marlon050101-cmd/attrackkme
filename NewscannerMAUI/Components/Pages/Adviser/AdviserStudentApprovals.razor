@page "/adviser/student-approvals"
@layout AdviserLayout
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject AuthService AuthService
@inject AdviserStateService AdviserState

<div class="approvals-container">
    <div class="page-header mb-3">
        <h5 class="fw-bold mb-0">Student Enrollment Approvals</h5>
        <p class="text-muted small mb-0">Review and accept students who have selected you as their adviser.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger small py-2 px-3 mb-3">
            <i class="fas fa-exclamation-circle me-1"></i> @errorMessage
        </div>
    }

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="height:200px;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (students == null || students.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-users-slash fa-2x text-muted opacity-40 mb-2"></i>
            <p class="text-muted small mb-0">No students found matching your adviser profile.</p>
        </div>
    }
    else
    {
        <div class="student-list">
            @foreach (var student in students)
            {
                <div class="student-card">
                    <div class="student-card-top">
                        <div class="d-flex align-items-center gap-2">
                            <div class="avatar-circle">
                                <i class="fas fa-user-graduate"></i>
                            </div>
                            <div>
                                <div class="fw-bold student-name">@student.FullName</div>
                                <div class="text-muted student-sub">Grade @student.GradeLevel &mdash; @student.Section
                                    @if (!string.IsNullOrEmpty(student.Strand))
                                    {
                                        <span> &bull; @student.Strand</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <span class="status-pill @GetStatusClass(student.EnrollmentStatus)">@student.EnrollmentStatus</span>
                    </div>

                    <div class="meta-row-compact">
                        <div class="meta-inline">
                            <span class="meta-label">Gender:</span>
                            <span class="meta-val">@student.Gender</span>
                        </div>
                        <div class="meta-inline">
                            <span class="meta-label">Guardian:</span>
                            <span class="meta-val">@student.ParentsNumber</span>
                        </div>
                    </div>

                    <div class="action-row">
                        @if (student.EnrollmentStatus == "Pending")
                        {
                            <button class="btn-action-sm btn-approve" @onclick='() => UpdateStatus(student, "Approved")'>
                                <i class="fas fa-check me-1"></i>Approve
                            </button>
                            <button class="btn-action-sm btn-reject-outline" @onclick='() => UpdateStatus(student, "Rejected")'>
                                <i class="fas fa-times me-1"></i>Reject
                            </button>
                        }
                        else if (student.EnrollmentStatus == "Approved")
                        {
                            <button class="btn-action-sm btn-remove" @onclick='() => UpdateStatus(student, "Pending")'>
                                <i class="fas fa-undo me-1"></i>Remove/Revert to Pending
                            </button>
                        }
                        else if (student.EnrollmentStatus == "Rejected")
                        {
                            <button class="btn-action-sm btn-secondary" @onclick='() => UpdateStatus(student, "Pending")'>
                                <i class="fas fa-redo me-1"></i>Review Again
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .approvals-container {
        padding: 1rem;
        max-width: 680px;
        margin: 0 auto;
    }

    .page-header h5 {
        font-size: 1.05rem;
    }

    /* ---- Empty State ---- */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 180px;
        background: #f8f9fa;
        border-radius: 16px;
        text-align: center;
        padding: 2rem;
    }

    /* ---- Student List ---- */
    .student-list {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    /* ---- Student Card ---- */
    .student-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 16px;
        padding: 0.85rem 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .student-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.6rem;
    }

    /* ---- Avatar ---- */
    .avatar-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(13,110,253,0.1);
        color: #0d6efd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .student-name {
        font-size: 0.9rem;
        line-height: 1.2;
    }

    .student-sub {
        font-size: 0.72rem;
    }

    /* ---- Status Pill ---- */
    .status-pill {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }

    .pill-pending  { background: #fff3cd; color: #856404; }
    .pill-approved { background: #d1e7dd; color: #0f5132; }
    .pill-rejected { background: #f8d7da; color: #842029; }

    /* ---- Meta Row Compact ---- */
    .meta-row-compact {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        padding: 0.25rem 0.5rem;
        margin-bottom: 0.75rem;
        border-bottom: 1px solid #f1f3f5;
    }

    .meta-inline {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .meta-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #adb5bd;
    }

    .meta-val {
        font-size: 0.75rem;
        font-weight: 600;
        color: #495057;
    }

    /* ---- Action Buttons Smaller ---- */
    .action-row {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.25rem;
    }

    .btn-action-sm {
        flex: 1;
        padding: 0.35rem 0.8rem;
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .btn-approve {
        background: #198754;
        color: #fff;
    }

    .btn-reject-outline {
        background: transparent;
        color: #dc3545;
        border: 1px solid #dc3545 !important;
    }

    .btn-remove {
        background: #f8f9fa;
        color: #6c757d;
        border: 1px solid #dee2e6 !important;
        font-size: 0.7rem;
    }

    .btn-secondary {
        background: #e9ecef;
        color: #495057;
    }

    .btn-action-sm:hover {
        opacity: 0.85;
        transform: translateY(-1px);
    }

    .btn-action-sm:active {
        transform: scale(0.98);
    }
</style>

@code {
    private List<StudentDisplayInfo>? students;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var currentUser = await AuthService.GetCurrentUserAsync();

            if (currentUser != null && !string.IsNullOrEmpty(currentUser.TeacherId))
            {
                var http = HttpClientFactory.CreateClient("AttrakAPI");
                var response = await http.GetAsync($"api/register/adviser/{currentUser.TeacherId}/students");

                if (response.IsSuccessStatusCode)
                {
                    students = await response.Content.ReadFromJsonAsync<List<StudentDisplayInfo>>();
                }
                else
                {
                    var body = await response.Content.ReadAsStringAsync();
                    errorMessage = $"Failed to load students ({response.StatusCode}).";
                }
            }
            else
            {
                errorMessage = "No adviser account linked. Please contact support.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Connection error. Please try again.";
            Console.WriteLine($"Error loading students: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatus(StudentDisplayInfo student, string newStatus)
    {
        try
        {
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var response = await http.PostAsJsonAsync($"api/register/student/{student.StudentId}/status", new { status = newStatus });

            if (response.IsSuccessStatusCode)
            {
                student.EnrollmentStatus = newStatus;
                var newCount = students?.Count(s => 
                    string.Equals(s.EnrollmentStatus, "Pending", StringComparison.OrdinalIgnoreCase)) ?? 0;
                AdviserState.SetPendingCount(newCount);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating status: {ex.Message}");
        }
    }

    private string GetStatusClass(string status) => status switch
    {
        "Approved" => "pill-approved",
        "Rejected" => "pill-rejected",
        _ => "pill-pending"
    };
}
