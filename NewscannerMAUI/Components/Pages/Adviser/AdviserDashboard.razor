@page "/adviser-dashboard"
@layout AdviserLayout
@using NewscannerMAUI.Services
@using AttrackSharedClass.Models
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject HttpClient Http
@inject OfflineDataService OfflineDataService

<div class="dashboard-container">
    <div class="welcome-banner">
        <h2 class="mb-1">Hello, @adviserName!</h2>
        <p class="text-muted small">Welcome to Sardo-TrackCare Adviser Portal</p>
    </div>

    <!-- Attendance Table Section -->
    <div class="attendance-table-section mt-1">
        <div class="section-header-flex">
            <h5 class="section-title mb-0">Attendance Monitoring</h5>
            <span class="live-indicator">
                <span class="dot"></span> LIVE
            </span>
        </div>
        <div class="table-container glass">
            @if (_isLoadingMonitoring)
            {
                <div class="text-center p-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2 small text-muted">Updating monitored list...</span>
                </div>
            }
            else
            {
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Status</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_dailySummaries.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted small">No students found in your section.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var summary in _dailySummaries.OrderBy(s => s.FullName))
                            {
                                <tr>
                                    <td>
                                        <div class="student-cell">
                                            <span class="student-name">@summary.FullName</span>
                                        </div>
                                    </td>
                                    <td><span class="status-badge @summary.Status.ToLower().Replace(" ", "-")">@summary.Status</span></td>
                                    <td>
                                        <div class="remarks-cell">
                                            <span class="small text-muted">@(string.IsNullOrEmpty(summary.Remarks) ? "No remarks" : summary.Remarks)</span>
                                            <div class="d-flex gap-2">
                                                @if (summary.Status != "Absent")
                                                {
                                                    <button class="btn-mark-absent" title="Mark Absent" @onclick="() => MarkAsAbsent(summary)">
                                                        <i class="fas fa-times-circle"></i>
                                                    </button>
                                                }
                                                <button class="btn-edit-remarks" title="Edit Remarks" @onclick="() => OpenRemarksModal(summary)">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Subject Attendance Table Section -->
    <div class="attendance-table-section mt-4 mb-4">
        <div class="section-header-flex">
            <h5 class="section-title mb-0">Subject Attendance</h5>
            <span class="subject-badge">TABBED VIEW</span>
        </div>
        
        <!-- Subject Tabs -->
        <div class="subject-tabs-container">
            @if (_isLoadingSubjects)
            {
                <div class="small text-muted p-2"><i class="fas fa-spinner fa-spin"></i> Loading subjects...</div>
            }
            else if (!_subjects.Any())
            {
                <div class="small text-muted p-2">No subjects assigned.</div>
            }
            else
            {
                <div class="subject-tabs">
                    @foreach (var sub in _subjects)
                    {
                        <button class="sub-tab @(activeSubjectId == sub.ClassOfferingId ? "active" : "")" @onclick='() => SetSubject(sub)'>
                            <i class="fas fa-book"></i> @sub.SubjectName
                        </button>
                    }
                </div>
            }
        </div>

        <div class="table-container glass">
            @if (_isLoadingSubjectAttendance)
            {
                <div class="text-center p-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2 small text-muted">Loading attendance...</span>
                </div>
            }
            else
            {
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Status</th>
                            <th>In</th>
                            <th>Out</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_subjectAttendanceRecords.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted small">No attendance records for this subject today.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var record in _subjectAttendanceRecords)
                            {
                                <tr>
                                    <td>
                                        <div class="student-cell">
                                            <div class="student-avatar-sm">@GetInitials(record.StudentName)</div>
                                            <div class="student-name">@record.StudentName</div>
                                        </div>
                                    </td>
                                    <td><span class="status-badge @record.Status.ToLower()">@record.Status</span></td>
                                    <td>@((record.TimeIn?.ToString("HH:mm") ?? "--:--"))</td>
                                    <td>@((record.TimeOut?.ToString("HH:mm") ?? "--:--"))</td>
                                    <td><span class="small text-muted">@record.Remarks</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Main Actions -->
    <div class="actions-section mt-4">
        <h5 class="section-title">Quick Actions</h5>
        <div class="action-buttons-grid">
            <button class="action-card classes" @onclick="GoToClasses">
                <div class="action-icon">
                    <i class="fas fa-plus-circle"></i>
                </div>
                <span class="action-text">Add/View Classes</span>
            </button>
            
            <button class="action-card monitoring" @onclick="GoToMonitoring">
                <div class="action-icon">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <span class="action-text">View Attendance</span>
            </button>
        </div>
    </div>
</div>

<!-- Manual Remarks Modal -->
@if (_showRemarksModal)
{
    <div class="confirm-overlay" @onclick="() => _showRemarksModal = false">
        <div class="confirm-box" @onclick:stopPropagation>
            <div class="modal-header-custom mb-3">
                <i class="fas fa-comment-dots text-primary"></i>
                <h3 class="mb-0">Update Remarks</h3>
                <small class="text-muted">@_selectedStudent?.FullName</small>
            </div>
            
            <div class="mb-3">
                <label class="form-label small fw-bold">Enter Remark:</label>
                <textarea class="form-control custom-textarea" 
                          placeholder="e.g., Sasakit, Uuwi, Emergency..." 
                          @bind="_editRemarksText"
                          rows="3"></textarea>
            </div>
            
            <div class="confirm-btns">
                <button class="btn-confirm-no" @onclick="() => _showRemarksModal = false">Cancel</button>
                <button class="btn-confirm-yes" @onclick="SaveSummaryRemarks" disabled="@_isSavingRemarks">
                    @if (_isSavingRemarks)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Save Remarks
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string adviserName = "Adviser";
    private string? adviserId;
    private string? activeSubjectId;
    
    private List<ClassOffering> _subjects = new();
    private List<DailySubjectSummary> _dailySummaries = new();
    private List<SubjectAttendanceRecord> _subjectAttendanceRecords = new();
    
    private bool _isLoadingSubjects = true;
    private bool _isLoadingMonitoring = true;
    private bool _isLoadingSubjectAttendance = false;

    // Remarks modal state
    private bool _showRemarksModal = false;
    private string _editRemarksText = "";
    private DailySubjectSummary? _selectedStudent;
    private bool _isSavingRemarks = false;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user != null)
        {
            adviserName = user.Username;
            adviserId = user.TeacherId;
            
            if (!string.IsNullOrEmpty(adviserId))
            {
                await LoadDashboardData();
            }
        }
    }

    private async Task LoadDashboardData()
    {
        _isLoadingSubjects = true;
        _isLoadingMonitoring = true;
        StateHasChanged();
        try
        {
            // Always fetch subjects fresh from API for Adviser dashboard
            // (Offline SQLite cache is only populated for Subject Teacher QR scanner flow)
            try
            {
                var list = await Http.GetFromJsonAsync<List<ClassOffering>>($"{ApiConfig.BaseUrl}api/SubjectAttendance/adviser/{adviserId}/subjects");
                _subjects = list ?? new();
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error fetching subjects from API: {ex.Message}");
                // Fall back to offline cache if API unavailable
                _subjects = await OfflineDataService.GetClassOfferingsOfflineAsync(adviserId!);
            }

            // Load monitored students and their statuses based on subject attendance
            try
            {
                var date = DateTime.Today.ToString("yyyy-MM-dd");
                var summaries = await Http.GetFromJsonAsync<List<DailySubjectSummary>>($"{ApiConfig.BaseUrl}api/SubjectAttendance/adviser/{adviserId}/daily-summary/{date}");
                _dailySummaries = summaries ?? new();
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error fetching daily summaries: {ex.Message}");
                _dailySummaries = new();
            }

            if (_subjects.Any())
            {
                await SetSubject(_subjects.First());
            }
        }
        finally
        {
            _isLoadingSubjects = false;
            _isLoadingMonitoring = false;
            StateHasChanged();
        }
    }

    private async Task SetSubject(ClassOffering subject)
    {
        activeSubjectId = subject.ClassOfferingId;
        _isLoadingSubjectAttendance = true;
        try
        {
            var dateStr = DateTime.Today.ToString("yyyy-MM-dd");
            var response = await Http.GetFromJsonAsync<List<SubjectAttendanceRecord>>($"{ApiConfig.BaseUrl}api/SubjectAttendance/class-offering/{subject.ClassOfferingId}/date/{dateStr}?adviserId={adviserId}");
            if (response != null)
            {
                _subjectAttendanceRecords = response;
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading subject attendance: {ex.Message}");
            _subjectAttendanceRecords = new();
        }
        finally
        {
            _isLoadingSubjectAttendance = false;
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }

    private string GetAvatarClass(string status)
    {
        return status.ToLower() switch
        {
            "present" => "",
            "late" => "warning",
            "absent" => "secondary",
            _ => "info"
        };
    }

    private void GoToClasses() => Navigation.NavigateTo("/adviser/section-classes");
    private void GoToMonitoring() => Navigation.NavigateTo("/adviser/attendance-monitoring");

    private void OpenRemarksModal(DailySubjectSummary summary)
    {
        _selectedStudent = summary;
        _editRemarksText = summary.Remarks ?? "";
        _showRemarksModal = true;
    }

    private async Task SaveSummaryRemarks()
    {
        if (_selectedStudent == null) return;
        
        _isSavingRemarks = true;
        try
        {
            var dateStr = DateTime.Today.ToString("yyyy-MM-dd");
            var response = await Http.PutAsJsonAsync($"{ApiConfig.BaseUrl}api/SubjectAttendance/daily-summary/remarks?studentId={_selectedStudent.StudentId}&date={dateStr}", _editRemarksText);
            
            if (response.IsSuccessStatusCode)
            {
                _selectedStudent.Remarks = _editRemarksText;
                _showRemarksModal = false;
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error saving remarks: {ex.Message}");
        }
        finally
        {
            _isSavingRemarks = false;
        }
    }

    private async Task MarkAsAbsent(DailySubjectSummary summary)
    {
        try
        {
            var dateStr = DateTime.Today.ToString("yyyy-MM-dd");
            var response = await Http.PutAsJsonAsync($"{ApiConfig.BaseUrl}api/SubjectAttendance/daily-summary/status?studentId={summary.StudentId}&date={dateStr}", "Absent");
            
            if (response.IsSuccessStatusCode)
            {
                summary.Status = "Absent";
                // Optionally refresh all to ensure numbers sync
                // await LoadDashboardData(); 
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error marking absent: {ex.Message}");
        }
    }
}

