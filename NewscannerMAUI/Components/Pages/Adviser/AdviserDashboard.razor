    /* Subject Tabs Styling */
    .subject-tabs-container {
        padding: 0 1rem;
        margin-bottom: 1rem;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none; /* Firefox */
    }

    .subject-tabs-container::-webkit-scrollbar {
        display: none; /* Chrome/Safari */
    }

    .subject-tabs {
        display: flex;
        flex-wrap: nowrap;
        gap: 8px;
        background: #f1f5f9;
        padding: 4px;
        border-radius: 14px;
        width: max-content;
    }

    .sub-tab {
        border: none;
        background: transparent;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        cursor: pointer;
    }

    .sub-tab i {
        font-size: 0.9rem;
        opacity: 0.7;
    }

    .sub-tab.active {
        background: white;
        color: #10b981;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .sub-tab.active i {
        opacity: 1;
    }

    .premium-table td:last-child {
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
    }

    /* Actions Grid */
    .actions-section {
        padding: 0 1rem;
    }

    .action-buttons-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .action-card {
        background: white;
        border: 1px solid #f1f5f9;
        border-radius: 20px;
        padding: 1.5rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        width: 100%;
        position: relative;
        overflow: hidden;
    }

    .action-card::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        transform: translateY(100%);
        transition: transform 0.2s;
    }

    .action-card.classes::after { background: #10b981; }
    .action-card.monitoring::after { background: #6366f1; }

    .action-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.05);
    }

    .action-card:hover::after {
