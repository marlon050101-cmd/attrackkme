@page "/teacher-dashboard"
@layout TeacherLayout
@using NewscannerMAUI.Services
@using AttrackSharedClass.Models
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject NewscannerMAUI.Services.OfflineDataService OfflineDataService
@inject NewscannerMAUI.Services.ConnectionStatusService ConnectionStatusService

<div class="dashboard-container">

    <!-- Schedule Section with Tabs -->
    <div class="schedule-section">
        <div class="section-header">
            <h5 class="section-title">Schedule View</h5>
            @if (isRefreshing)
            {
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            }
            else
            {
                <button class="refresh-mini-btn" @onclick="LoadTeacherSchedule">
                    <i class="fas fa-sync-alt"></i>
                </button>
            }
        </div>

        <!-- Custom Tabs -->
        <div class="tabs-container">
            <div class="tab-item @(activeTab == "today" ? "active" : "")" @onclick='() => SetTab("today")'>
                <span>Today</span>
                @if (todayClasses?.Any() == true)
                {
                    <span class="tab-badge">@todayClasses.Count</span>
                }
            </div>
            <div class="tab-item @(activeTab == "weekly" ? "active" : "")" @onclick='() => SetTab("weekly")'>
                <span>Weekly</span>
            </div>
        </div>

        <div class="schedule-list">
            @if (activeTab == "today")
            {
                @if (todayClasses == null || !todayClasses.Any())
                {
                    <div class="empty-schedule">
                        <div class="empty-icon">
                            <i class="fas fa-calendar-day"></i>
                        </div>
                        <h6>No classes today</h6>
                        <p>Relax! You have no scheduled classes for today.</p>
                        <button class="btn-outline-custom mt-2" @onclick='() => SetTab("weekly")'>
                            View Weekly Schedule
                        </button>
                    </div>
                }
                else
                {
                    @foreach (var cls in todayClasses)
                    {
                        bool isActive = IsClassActive(cls);
                        <div class="schedule-card @(isActive ? "active-session" : "")">
                            <div class="time-slot">
                                <span class="time-start">@FormatTimeSpan(cls.ScheduleStart)</span>
                                <span class="time-end">@FormatTimeSpan(cls.ScheduleEnd)</span>
                            </div>
                            <div class="class-info">
                                <span class="subject-name">@cls.SubjectName</span>
                                <div class="class-meta">
                                    <span class="section"><i class="fas fa-users me-1"></i>@cls.Section</span>
                                    <span class="grade"><i class="fas fa-graduation-cap me-1"></i>G@cls.GradeLevel @cls.Strand</span>
                                </div>
                            </div>
                            <div class="class-action">
                                @if (isActive)
                                {
                                    <button class="scan-btn pulse" @onclick="() => GoToScanner()">
                                        <i class="fas fa-qrcode"></i>
                                        <span>SCAN</span>
                                    </button>
                                }
                                else if (cls.ScheduleStart > DateTime.Now.TimeOfDay)
                                {
                                    <span class="upcoming-tag">UPCOMING</span>
                                }
                                else
                                {
                                    <i class="fas fa-check-circle text-success opacity-50"></i>
                                }
                            </div>
                        </div>
                    }
                }
            }
            else // Weekly Tab
            {
                @if (allClasses == null || !allClasses.Any())
                {
                    <div class="empty-schedule">
                        <div class="empty-icon">
                            <i class="fas fa-book-open"></i>
                        </div>
                        <h6>No subjects assigned</h6>
                        <p>You haven't joined any classes yet.</p>
                        <button class="btn-primary-custom mt-2" @onclick='() => Navigation.NavigateTo("/teacher/subject-selection")'>
                            Join Classes
                        </button>
                    </div>
                }
                else
                {
                    @foreach (var cls in allClasses)
                    {
                        <div class="schedule-card weekly-card">
                            <div class="day-indicator">
                                @foreach (var day in GetShortDays(cls.DayOfWeek))
                                {
                                    <span class="day-chip @(IsDayToday(day) ? "today" : "")">@day</span>
                                }
                            </div>
                            <div class="class-info">
                                <span class="subject-name">@cls.SubjectName</span>
                                <div class="class-meta">
                                    <span class="time"><i class="far fa-clock me-1"></i>@FormatTimeSpan(cls.ScheduleStart) - @FormatTimeSpan(cls.ScheduleEnd)</span>
                                    <span class="section"><i class="fas fa-users me-1"></i>@cls.Section</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>

    <!-- Offline Records Card -->
    @if (offlineRecordCount > 0)
    {
        <div class="offline-alert-card mt-4" @onclick="GoToScanner">
            <div class="alert-icon">
                <i class="fas fa-cloud-upload-alt"></i>
            </div>
            <div class="alert-content">
                <span class="alert-title">Pending Sync</span>
                <span class="alert-text">You have @offlineRecordCount unsynced records.</span>
            </div>
            <i class="fas fa-chevron-right ms-auto"></i>
        </div>
    }
</div>

@code {
    private string teacherName = "Subject Teacher";
    private List<ClassOffering>? todayClasses;
    private List<ClassOffering>? allClasses;
    private AttrackSharedClass.Models.UserInfo currentTeacher;
    private bool isRefreshing = false;
    private int offlineRecordCount = 0;
    private string activeTab = "today";

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user != null)
        {
            teacherName = user.FullName ?? user.Username;
            currentTeacher = user;
            await LoadTeacherSchedule();
            await LoadOfflineRecordCount();
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private async Task LoadOfflineRecordCount()
    {
        offlineRecordCount = await OfflineDataService.GetUnsyncedCountAsync(currentTeacher?.TeacherId);
    }

    private async Task LoadTeacherSchedule()
    {
        try
        {
            isRefreshing = true;
            if (currentTeacher == null || string.IsNullOrEmpty(currentTeacher.TeacherId)) return;

            List<ClassOffering>? result = null;
            try 
            {
                var httpClient = HttpClientFactory.CreateClient("AttrakAPI");
                result = await httpClient.GetFromJsonAsync<List<ClassOffering>>($"api/ClassOffering/teacher/{currentTeacher.TeacherId}");
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Online schedule load failed: {ex.Message}");
            }
            
            if (result == null || !result.Any())
            {
                result = await OfflineDataService.GetClassOfferingsOfflineAsync(currentTeacher.TeacherId);
            }
            
            if (result != null)
            {
                allClasses = result.OrderBy(c => c.ScheduleStart).ToList();
                todayClasses = result.Where(c => MatchesToday(c.DayOfWeek))
                                       .OrderBy(c => c.ScheduleStart)
                                       .ToList();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading teacher schedule: {ex.Message}");
        }
        finally
        {
            isRefreshing = false;
            StateHasChanged();
        }
    }

    private bool IsClassActive(ClassOffering cls)
    {
        if (!MatchesToday(cls.DayOfWeek)) return false;
        
        var now = DateTime.Now.TimeOfDay;
        var bufferBefore = TimeSpan.FromMinutes(15);
        var bufferAfter = TimeSpan.FromMinutes(30);
        
        return now >= cls.ScheduleStart.Subtract(bufferBefore) && now <= cls.ScheduleEnd.Add(bufferAfter);
    }

    private bool MatchesToday(string dbDays)
    {
        if (string.IsNullOrEmpty(dbDays)) return false;
        
        var today = DateTime.Now.DayOfWeek;
        var dayNames = dbDays.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(d => d.Trim().ToLower());
        
        foreach (var d in dayNames)
        {
            if (d == "monday" || d == "mon" || d == "m") { if (today == DayOfWeek.Monday) return true; continue; }
            if (d == "tuesday" || d == "tue" || d == "t") { if (today == DayOfWeek.Tuesday) return true; continue; }
            if (d == "wednesday" || d == "wed" || d == "w") { if (today == DayOfWeek.Wednesday) return true; continue; }
            if (d == "thursday" || d == "thu" || d == "th") { if (today == DayOfWeek.Thursday) return true; continue; }
            if (d == "friday" || d == "fri" || d == "f") { if (today == DayOfWeek.Friday) return true; continue; }
            if (d == "saturday" || d == "sat" || d == "s") { if (today == DayOfWeek.Saturday) return true; continue; }
            if (d == "sunday" || d == "sun" || d == "su") { if (today == DayOfWeek.Sunday) return true; continue; }
        }
        return false;
    }

    private List<string> GetShortDays(string dbDays)
    {
        if (string.IsNullOrEmpty(dbDays)) return new List<string>();
        return dbDays.Split(',', StringSplitOptions.RemoveEmptyEntries)
                    .Select(d => d.Trim().Substring(0, 3).ToUpper())
                    .ToList();
    }

    private bool IsDayToday(string shortDay)
    {
        var todayShort = DateTime.Now.DayOfWeek.ToString().Substring(0, 3).ToUpper();
        return shortDay == todayShort;
    }

    private string FormatTimeSpan(TimeSpan ts) => DateTime.Today.Add(ts).ToString("h:mm tt");

    private void GoToScanner() => Navigation.NavigateTo("/qr-scanner");
}

<style>
    .dashboard-container {
        padding: 0;
    }



