    .tab-btn.active {
        background: white;
        color: #6f42c1;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }

    .glass {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
