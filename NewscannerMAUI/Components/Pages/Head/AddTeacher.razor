    @@media (max-width: 480px) {
        .generated-credentials-card .card-body {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }

    .btn-primary {
        width: 100%;
        padding: 1rem;
        background: #6f42c1;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
    }

    .btn-primary:hover:not(:disabled) {
