@code {
    private string activeTab = "register";
    private RegisterRequest newTeacher = new();
    private int selectedUserType = 0;
    private string generatedUsername = "";
    private string generatedPassword = "";
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool showValidation = false;

    private List<PendingTeacherInfo>? allTeachers;
    private string searchTerm = "";
    private bool isLoadingList = true;

    private bool showSuccessModal = false;
    private bool showDetailsModal = false;
    private bool isEditMode = false;
    private bool isUpdating = false;
    private PendingTeacherInfo? selectedTeacher;
    private UpdateTeacherRequest editModel = new();
    private string lastRegisteredName = "";
    private UserInfo? headUser;

    private void ToggleEdit()
    {
        if (selectedTeacher == null) return;
        
        isEditMode = !isEditMode;
        if (isEditMode)
        {
            editModel = new UpdateTeacherRequest
            {
                FullName = selectedTeacher.FullName,
                Email = selectedTeacher.Email,
                GradeLevel = selectedTeacher.GradeLevel,
                Section = selectedTeacher.Section,
                Strand = selectedTeacher.Strand
            };
        }
    }

    private async Task HandleUpdate()
    {
        if (selectedTeacher == null) return;

        try
        {
            isUpdating = true;
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var response = await http.PutAsJsonAsync($"/api/teacher/update-info/{selectedTeacher.UserId}", editModel);

            if (response.IsSuccessStatusCode)
            {
                // Update local list
                selectedTeacher.FullName = editModel.FullName;
                selectedTeacher.Email = editModel.Email;
                selectedTeacher.GradeLevel = editModel.GradeLevel;
                selectedTeacher.Section = editModel.Section;
                selectedTeacher.Strand = editModel.Strand;
                
                isEditMode = false;
            }
            else
            {
                errorMessage = "Failed to update teacher information.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Update error: " + ex.Message;
        }
        finally
        {
            isUpdating = false;
        }
    }

    private void ShowTeacherDetails(PendingTeacherInfo teacher)
    {
        selectedTeacher = teacher;
        showDetailsModal = true;
        isEditMode = false;
        errorMessage = null;
    }

    private async Task ShareTeacherCredentials(string name, string username, string password)
    {
        try
        {
            var text = $"Teacher Credentials for {name}:\n\nUsername: {username}\nPassword: {password}\n\nPlease keep these details secure.";
            await Share.RequestAsync(new ShareTextRequest
            {
                Text = text,
                Title = "Share Teacher Credentials"
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sharing: {ex.Message}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        headUser = await AuthService.GetCurrentUserAsync();
        if (headUser == null)
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadTeachers();
        GeneratePassword();
    }

    private void UpdateGeneratedUsername(ChangeEventArgs e)
    {
        var name = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(name))
        {
            generatedUsername = "";
            return;
        }

        // Clean name and take first part + 4 random digits
        var cleanName = new string(name.ToLower().Where(c => char.IsLetter(c)).ToArray());
        if (cleanName.Length > 8) cleanName = cleanName.Substring(0, 8);
        
        var random = new Random();
        generatedUsername = $"{cleanName}{random.Next(1000, 9999)}";
    }

    private void GeneratePassword()
    {
        const string chars = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789";
        var random = new Random();
        generatedPassword = new string(Enumerable.Repeat(chars, 8)
            .Select(s => s[random.Next(s.Length)]).ToArray());
    }

    private async Task HandleRegister()
    {
        showValidation = true;
        
        bool isAdvisorIncomplete = selectedUserType == (int)UserType.Advisor && 
            ((newTeacher.GradeLevel == null || newTeacher.GradeLevel == 0) || 
             string.IsNullOrWhiteSpace(newTeacher.Section) || 
             (newTeacher.GradeLevel >= 11 && string.IsNullOrWhiteSpace(newTeacher.Strand)));

        if (selectedUserType == 0 || string.IsNullOrWhiteSpace(newTeacher.FullName) || string.IsNullOrWhiteSpace(newTeacher.Email) || isAdvisorIncomplete)
        {
            errorMessage = "Please fill in all required fields.";
            return;
        }

        try
        {
            isSubmitting = true;
            errorMessage = null;
            newTeacher.UserType = (UserType)selectedUserType;

            // Pre-fill from Head's info
            newTeacher.Username = generatedUsername;
            newTeacher.Password = generatedPassword;
            
            // We need school info
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var schoolInfo = await http.GetFromJsonAsync<SchoolInfo>($"/api/register/school/{headUser.SchoolId}");
            
            if (schoolInfo == null)
            {
                errorMessage = "Failed to retrieve school information.";
                return;
            }

            newTeacher.SchoolName = schoolInfo.SchoolName;
            newTeacher.Region = schoolInfo.Region;
            newTeacher.Division = schoolInfo.Division;
            newTeacher.District = schoolInfo.District;

            var response = await http.PostAsJsonAsync("/api/register/teacher", newTeacher);
            
            if (response.IsSuccessStatusCode)
            {
                lastRegisteredName = newTeacher.FullName;
                showSuccessModal = true;
                // Don't reset everything yet so user can see credentials in modal
            }
            else
            {
                var errorResponse = await response.Content.ReadFromJsonAsync<RegisterResponse>();
                errorMessage = errorResponse?.Message ?? "Registration failed. Username or Email might already exist.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task LoadTeachers()
    {
        try
        {
            isLoadingList = true;
            if (headUser?.SchoolId != null)
            {
                var http = HttpClientFactory.CreateClient("AttrakAPI");
                allTeachers = await http.GetFromJsonAsync<List<PendingTeacherInfo>>($"/api/teacher/all/{headUser.SchoolId}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading teachers list: " + ex.Message);
        }
        finally
        {
            isLoadingList = false;
        }
    }

    private List<PendingTeacherInfo>? filteredTeachers => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? allTeachers 
            : allTeachers?.Where(t => t.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

    private void CloseSuccessModal()
    {
        showSuccessModal = false;
        newTeacher = new();
        selectedUserType = 0;
        showValidation = false;
        generatedUsername = "";
        GeneratePassword();
        _ = LoadTeachers(); // Refresh list in background
    }
}
