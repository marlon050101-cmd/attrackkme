@page "/head/add-teacher"
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@layout HeadLayout
@inject IHttpClientFactory HttpClientFactory
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="add-teacher-container">
    <div class="page-header">
        <div class="header-icon">
            <i class="fas fa-user-plus"></i>
        </div>
        <div class="header-text">
            <h1>Teacher Management</h1>
            <p>Register new staff or manage existing accounts</p>
        </div>
    </div>

    <div class="tabs-container">
        <button class="tab-btn @(activeTab == "register" ? "active" : "")" @onclick='() => activeTab = "register"'>
            <i class="fas fa-user-plus"></i> Register Teacher
        </button>
        <button class="tab-btn @(activeTab == "list" ? "active" : "")" @onclick='() => activeTab = "list"'>
            <i class="fas fa-list"></i> Teacher List
        </button>
    </div>

    <div class="tab-content">
        @if (activeTab == "register")
        {
            <div class="register-form glass fade-in">
                <div class="generated-credentials-card">
                    <div class="card-header">
                        <i class="fas fa-magic"></i>
                        <span>Generated User & Password</span>
                    </div>
                    <div class="card-body">
                        <div class="cred-group">
                            <label>Username</label>
                            <div class="cred-value">@(string.IsNullOrEmpty(generatedUsername) ? "Enter name to generate..." : generatedUsername)</div>
                        </div>
                        <div class="cred-group">
                            <label>Password</label>
                            <div class="cred-value">@generatedPassword</div>
                        </div>
                    </div>
                </div>

                <div class="form-group @(showValidation && selectedUserType == 0 ? "invalid" : "")">
                    <label>Account Type</label>
                    <div class="input-wrapper">
                        <i class="fas fa-user-tag"></i>
                        <select @bind="selectedUserType" class="select-input">
                            <option value="0" disabled selected>-- Choose Account Type --</option>
                            <option value="@((int)UserType.Teacher)">Subject Teacher</option>
                            <option value="@((int)UserType.Advisor)">Advisor</option>
                        </select>
                    </div>
                </div>

                <div class="form-group @(showValidation && string.IsNullOrWhiteSpace(newTeacher.FullName) ? "invalid" : "")">
                    <label>Full Name <span class="hint"><i>(Last name, First name MI)</i></span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-user"></i>
                        <input type="text" @bind="newTeacher.FullName" placeholder="e.g. Doe, John D." @oninput="UpdateGeneratedUsername" />
                    </div>
                </div>

                <div class="form-group @(showValidation && string.IsNullOrWhiteSpace(newTeacher.Email) ? "invalid" : "")">
                    <label>Email Address</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" @bind="newTeacher.Email" placeholder="e.g. john@example.com" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-msg">
                        <i class="fas fa-exclamation-circle"></i> @errorMessage
                    </div>
                }

                <button class="btn-primary" @onclick="HandleRegister" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <div class="spinner-sm"></div>
                    }
                    else
                    {
                        <span>Register Teacher</span>
                    }
                </button>
            </div>
        }
        else
        {
            <div class="teacher-list-tab fade-in">
                <div class="list-controls">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search by name..." />
                    </div>
                </div>

                @if (isLoadingList)
                {
                    <div class="loading-state">
                        <div class="spinner"></div>
                        <p>Fetching teacher records...</p>
                    </div>
                }
                else if (filteredTeachers == null || !filteredTeachers.Any())
                {
                    <div class="empty-state">
                        <i class="fas fa-users-slash"></i>
                        <p>No teachers found.</p>
                    </div>
                }
                else
                {
                    <div class="teacher-list compact">
                        @foreach (var teacher in filteredTeachers)
                        {
                            <div class="teacher-row glass" @onclick="() => ShowTeacherDetails(teacher)">
                                <div class="row-main">
                                    <div class="row-avatar">
                                        @teacher.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="row-info">
                                        <div class="row-name">@teacher.FullName</div>
                                        <div class="row-username">@@@teacher.Username</div>
                                    </div>
                                </div>
                                <div class="row-status @teacher.UserType.ToLower()">
                                    @teacher.UserType
                                </div>
                                <i class="fas fa-chevron-right row-arrow"></i>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (showDetailsModal && selectedTeacher != null)
{
    <div class="modal-overlay">
        <div class="details-modal scale-in">
            <div class="modal-header">
                <div class="details-avatar">@selectedTeacher.FullName.Substring(0, 1).ToUpper()</div>
                <h3>Teacher Information</h3>
                <button class="close-modal" @onclick="() => showDetailsModal = false">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="info-item">
                    <label>Full Name</label>
                    <div class="info-text">@selectedTeacher.FullName</div>
                </div>
                <div class="info-item">
                    <label>Email Address</label>
                    <div class="info-text">@selectedTeacher.Email</div>
                </div>
                <div class="info-item">
                    <label>User Type</label>
                    <div class="info-text">@selectedTeacher.UserType</div>
                </div>

                <div class="credentials-section">
                    <div class="cred-header">
                        <i class="fas fa-key"></i>
                        <span>Account Access</span>
                        <button class="btn-share-icon" title="Share Credentials" @onclick="() => ShareTeacherCredentials(selectedTeacher.FullName, selectedTeacher.Username, selectedTeacher.Password)">
                            <i class="fas fa-share-alt"></i>
                        </button>
                    </div>
                    <div class="cred-item">
                        <label>Username</label>
                        <div class="cred-value">@selectedTeacher.Username</div>
                    </div>
                    <div class="cred-item">
                        <label>Password</label>
                        <div class="cred-value">@selectedTeacher.Password</div>
                    </div>
                </div>
            </div>
            <button class="btn-close" @onclick="() => showDetailsModal = false">Close</button>
        </div>
    </div>
}

@if (showSuccessModal)
{
    <div class="modal-overlay">
        <div class="success-modal scale-in">
            <div class="success-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h3>Registration Successful!</h3>
            <p><strong>@lastRegisteredName</strong> has been registered.</p>
            <div class="modal-credentials">
                <p>Username: <code>@generatedUsername</code></p>
                <p>Password: <code>@generatedPassword</code></p>
                <button class="btn-share-inline" @onclick="() => ShareTeacherCredentials(lastRegisteredName, generatedUsername, generatedPassword)">
                    <i class="fas fa-share-alt"></i> Share to Messenger/Other
                </button>
            </div>
            <p class="warning-text">Please share these credentials with the teacher.</p>
            <button class="btn-done" @onclick="CloseSuccessModal">Done</button>
        </div>
    </div>
}

<style>
    .add-teacher-container {
        padding: 1.5rem 1rem;
        max-width: 800px;
        margin: 0 auto;
        font-family: 'Inter', sans-serif;
        box-sizing: border-box;
    }

    @@media (max-width: 600px) {
        .add-teacher-container {
            padding: 1rem 0.75rem;
        }
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #6f42c1 0%, #4b2ea2 100%);
        color: white;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        box-shadow: 0 10px 20px rgba(111, 66, 193, 0.2);
    }

    .header-text h1 {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    .header-text p {
        margin: 0.2rem 0 0;
        color: #64748b;
        font-weight: 500;
        font-size: 0.95rem;
    }

    @@media (max-width: 480px) {
        .header-text h1 { font-size: 1.3rem; }
        .header-text p { font-size: 0.85rem; }
    }

    .tabs-container {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        background: #f1f5f9;
        padding: 0.4rem;
        border-radius: 16px;
    }

    .tab-btn {
        flex: 1;
        padding: 0.75rem 0.5rem;
        border: none;
        background: transparent;
        color: #64748b;
        font-weight: 700;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        white-space: nowrap;
