@page "/head/advisor-subjects"
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@layout HeadLayout
@inject IHttpClientFactory HttpClientFactory
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="asgn-container">
    <div class="page-header">
        <div class="header-text">
            <h1>Class Schedule</h1>
            <p>Advisor Class management</p>
        </div>
    </div>

    @* Grade Filter Pills *@
    <div class="grade-filter-container">
        <div class="grade-filter-pills">
            <button class="filter-pill @(selectedGrade == null ? "active" : "")" @onclick="() => FilterByGrade(null)">All</button>
            @foreach (var g in new[] { 7, 8, 9, 10, 11, 12 })
            {
                <button class="filter-pill @(selectedGrade == g ? "active" : "")" @onclick="() => FilterByGrade(g)">Grade @g</button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="shimmer-card"></div>
            <div class="shimmer-card"></div>
            <p>Loading advisors...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-panel">
            <div class="error-icon"><i class="fas fa-circle-exclamation"></i></div>
            <div class="error-content">
                <strong>Error</strong>
                <p>@errorMessage</p>
            </div>
            <button class="btn-retry" @onclick="LoadAdvisors">Try Again</button>
        </div>
    }
    else if (!advisors.Any())
    {
        <div class="empty-state glass">
            <div class="empty-icon"><i class="fas fa-user-tie"></i></div>
            <h3>No Advisors Yet</h3>
            <p>There are no approved advisors in your school yet.</p>
        </div>
    }
    else
    {
        <div class="list-wrapper">
            <div class="list-meta">
                <span>@(filteredAdvisors.Count) Advisor@(filteredAdvisors.Count != 1 ? "s" : "")</span>
            </div>

            <div class="advisor-list">
                @foreach (var advisor in filteredAdvisors)
                {
                    <div class="advisor-card glass-hover fade-in">
                        <div class="advisor-meta">
                            <div class="advisor-info">
                                <h3 class="advisor-name">@advisor.FullName</h3>
                                <div class="advisor-badge">
                                    @if (advisor.GradeLevel.HasValue)
                                    {
                                        <span>Grade @advisor.GradeLevel</span>
                                    }
                                    @if (!string.IsNullOrEmpty(advisor.Section))
                                    {
                                        <span> • @advisor.Section</span>
                                    }
                                    @if (!string.IsNullOrEmpty(advisor.Strand))
                                    {
                                        var displayStrand = advisor.Strand.Contains("Academic") ? "Academic" : (advisor.Strand.Contains("Tech") ? "TechPro" : advisor.Strand);
                                        <span> • @displayStrand</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <button class="btn-manage" @onclick="() => OpenManageModal(advisor)">
                            <span>Manage</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* ─── Manage Modal (Redesigned) ─── *@
@if (showManageModal && selectedAdvisor != null)
{
    <div class="modal-overlay" @onclick="CloseManageModal">
        <div class="header-gradient-bg"></div>
        <div class="premium-modal fade-in" @onclick:stopPropagation="true">
            @* Advisor Profile Section *@
            <div class="profile-section">
                <div class="profile-meta">
                    <div class="profile-details">
                        <h3 class="profile-name">@selectedAdvisor.FullName</h3>
                        <p class="profile-sub">
                            Grade @(selectedAdvisor.GradeLevel ?? 0) • @(selectedAdvisor.Section ?? "No Section")
                            @if (!string.IsNullOrEmpty(selectedAdvisor.Strand))
                            {
                                <span> • @selectedAdvisor.Strand</span>
                            }
                        </p>
                    </div>
                </div>
                <button class="btn-close-minimal" @onclick="CloseManageModal"><i class="fas fa-times"></i></button>
            </div>

            <div class="modal-body-content">
                @* Current Subjects Section *@
                <div class="section-container">
                    <div class="section-header">
                        <i class="fas fa-list-ul"></i>
                        <span>CURRENT SUBJECTS</span>
                    </div>
                    
                    @if (isLoadingClasses)
                    {
                        <div class="mini-loading"><div class="spinner-xl"></div></div>
                    }
                    else if (!currentClasses.Any())
                    {
                        <div class="empty-subjects-placeholder">
                            No subjects assigned yet.
                        </div>
                    }
                    else
                    {
                        <div class="subject-chips-list">
                            @foreach (var cls in currentClasses.OrderBy(c => c.ScheduleStart))
                            {
                                <div class="premium-subject-chip">
                                    <div class="chip-main-content">
                                        <div class="chip-row-top">
                                            <span class="chip-name">@cls.SubjectName</span>
                                            @if (!string.IsNullOrEmpty(cls.SubjectCode))
                                            {
                                                <span class="chip-code">@cls.SubjectCode</span>
                                            }
                                        </div>
                                        <div class="chip-row-bottom">
                                            <span class="chip-time">@cls.ScheduleStart.ToString(@"hh\:mm") – @cls.ScheduleEnd.ToString(@"hh\:mm")</span>
                                            @if (!string.IsNullOrEmpty(cls.DayOfWeek))
                                            {
                                                <span class="chip-days">(@FormatDays(cls.DayOfWeek))</span>
                                            }
                                        </div>
                                    </div>
                                    <button class="btn-chip-remove" @onclick="() => ConfirmRemove(cls)">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Add Subject Section *@
                <div class="section-container mt-4">
                    <div class="section-header">
                        <i class="fas fa-plus-circle"></i>
                        <span>ADD SUBJECT</span>
                    </div>

                    <div class="premium-form">
                        @* Subject Picker *@
                        <div class="premium-field">
                            <label>SUBJECT</label>
                            <div class="subject-autocomplete">
                                <input type="text" class="premium-input" placeholder="Search or type subject name..."
                                       value="@subjectSearchText"
                                       @oninput="OnSubjectSearch"
                                       @onfocus="() => showDropdown = true" />
                                
                                <i class="fas fa-search search-inside-icon"></i>

                                @if (showDropdown && filteredSubjects.Any())
                                {
                                    <div class="premium-dropdown">
                                        @foreach (var s in filteredSubjects)
                                        {
                                            <div class="dropdown-row @(s.SubjectId == selectedSubjectId ? "active" : "")"
                                                 @onclick="() => SelectSubject(s)">
                                                <div class="row-text">
                                                    <strong>@s.SubjectName</strong>
                                                    @if (!string.IsNullOrEmpty(s.SubjectCode))
                                                    {
                                                        <span class="row-code">@s.SubjectCode</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(s.Strand))
                                                {
                                                    <span class="row-strand">@s.Strand</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(selectedSubjectId))
                            {
                                <div class="selection-pill">
                                    <i class="fas fa-check-circle"></i>
                                    <span>@subjectSearchText</span>
                                    <button @onclick="ClearSubject">×</button>
                                </div>
                            }
                        </div>

                        @* Day Picker *@
                        <div class="premium-field">
                            <label>DAYS</label>
                            <div class="pill-day-picker">
                                @foreach (var day in AllDays)
                                {
                                    var active = selectedDays.Contains(day);
                                    <button type="button" class="pill-btn @(active ? "active" : "")"
                                            @onclick="() => ToggleDay(day)">
                                        @day.Substring(0, 3)
                                    </button>
                                }
                            </div>
                        </div>

                        @* Time Selection *@
                        <div class="premium-row">
                            <div class="premium-field flex-1">
                                <label>START TIME</label>
                                <div class="select-wrapper">
                                    @* We'll use input type="time" but style it premium *@
                                    <input type="time" class="premium-input" value="@startTime" @onchange="OnStartTimeChange" />
                                </div>
                            </div>
                            <div class="premium-field flex-1">
                                <label>END TIME</label>
                                <div class="select-wrapper">
                                    <input type="time" class="premium-input" value="@endTime" @onchange="OnEndTimeChange" />
                                </div>
                            </div>
                        </div>

                        @* Action Button *@
                        <button class="btn-premium-action" @onclick="AddSubject" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <div class="loader-sm"></div>
                            }
                            else
                            {
                                <i class="fas fa-plus"></i>
                                <span>Add Subject</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


@* ─── Remove Confirm ─── *@
@if (showRemoveConfirm && classToRemove != null)
{
    <div class="modal-overlay" @onclick="() => showRemoveConfirm = false">
        <div class="confirm-modal scale-in" @onclick:stopPropagation="true">
            <div class="confirm-icon"><i class="fas fa-trash-alt"></i></div>
            <h4>Remove Subject?</h4>
            <p>Remove <strong>@classToRemove.SubjectName</strong> from @selectedAdvisor?.FullName's schedule?</p>
            <div class="confirm-actions">
                <button class="btn-cancel" @onclick="() => showRemoveConfirm = false">Cancel</button>
                <button class="btn-confirm-remove" @onclick="ExecuteRemove" disabled="@isRemoving">
                    @if (isRemoving) { <div class="spinner-sm white"></div> } else { <span>Remove</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ─── Modern Snackbar ─── *@
<div class="snackbar-host @(showSnackbar ? "active" : "") @snackbarType">
    <div class="snackbar-box">
        <div class="snackbar-icon"><i class="@snackbarIcon"></i></div>
        <div class="snackbar-message">@snackbarMessage</div>
        <div class="snackbar-progress"></div>
    </div>
</div>

<style>
    :root {
        --primary-purple: #7c3aed;
        --secondary-purple: #4c1d95;
        --soft-purple-bg: #f5f3ff;
        --text-dark: #1e293b;
        --text-muted: #64748b;
        --radius-lg: 28px;
        --radius-md: 16px;
        --shadow-soft: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    }

    .asgn-container {
        padding: 0;
        max-width: 600px;
        margin: 0 auto;
        font-family: 'Outfit', sans-serif;
        min-height: 100vh;
        background: #f8fafc;
    }

    .page-header {
        background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 100%);
        padding: 1.5rem 1.25rem;
        margin-bottom: 1.25rem;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 20px -5px rgba(0, 0, 0, 0.1);
    }

    .page-header h1 {
        font-size: 1.75rem;
        font-weight: 900;
        color: white;
        margin: 0;
        letter-spacing: -0.5px;
        line-height: 1;
    }

    .page-header p {
        color: rgba(255, 255, 255, 0.8);
        margin: 0.4rem 0 0;
        font-weight: 500;
        font-size: 0.95rem;
        line-height: 1.2;
    }

    /* Grade Filter */
    .grade-filter-container {
        padding: 0 1.25rem 1rem;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    .grade-filter-container::-webkit-scrollbar { display: none; }
    
    .grade-filter-pills {
        display: flex;
        gap: 0.5rem;
        width: max-content;
    }

    .filter-pill {
        background: white;
        border: 1px solid #e2e8f0;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }
    .filter-pill.active {
        background: var(--primary-purple);
        border-color: var(--primary-purple);
        color: white;
        box-shadow: 0 4px 10px rgba(124, 58, 237, 0.2);
    }

    /* List Design */
    .list-wrapper { padding: 0 1.25rem 2rem; }

    .list-meta {
        margin-bottom: 1rem;
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .list-meta::before {
        content: "";
        display: block;
        width: 4px;
        height: 16px;
        background: var(--primary-purple);
        border-radius: 2px;
    }

    .advisor-list { display: flex; flex-direction: column; gap: 0.75rem; }

    .advisor-card {
        background: white;
        border-radius: 20px;
        padding: 1.15rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .advisor-card:hover {
        transform: translateY(-4px);
        border-color: #ede9fe;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
    }

    .advisor-meta { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 0; }

    .advisor-avatar {
        width: 48px;
        height: 48px;
        background: #fef3c7;
        color: #92400e;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .advisor-info { min-width: 0; }
    .advisor-name { font-size: 1rem; font-weight: 800; color: var(--text-dark); margin: 0 0 0.2rem; }
    .advisor-badge { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }

    .btn-manage {
        background: #1e293b;
        color: white;
        border: none;
        padding: 0.65rem 1.1rem;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.82rem;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-manage:hover {
        background: var(--primary-purple);
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
        transform: scale(1.03);
    }

    /* Modal Context - Overlay & Premium Modal */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: flex-end; /* Mobile feel: slides from bottom */
        justify-content: center;
        z-index: 2000;
        padding: 0;
    }

    /* Desktop adjust for overlay */
    @@media (min-width: 768px) {
        .modal-overlay { align-items: center; padding: 1rem; }
    }

    .premium-modal {
        position: relative;
        background: white;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        width: 100%;
        max-width: 440px;
        max-height: 92vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 -10px 40px rgba(0,0,0,0.2);
        z-index: 2001;
        animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@media (min-width: 768px) {
        .premium-modal { border-radius: var(--radius-lg); animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
    }

    .header-gradient-bg {
        display: none; /* Already handled by page background or modal context if needed */
    }

    /* Profile Section (Header inside Modal) */
    .profile-section {
        padding: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #f1f5f9;
        background: white;
    }

    .profile-meta { display: flex; align-items: center; gap: 1rem; }

    .profile-avatar {
        width: 60px;
        height: 60px;
        background: #fef3c7;
        color: #92400e;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.5rem;
        box-shadow: 0 4px 12px rgba(254, 243, 199, 0.5);
    }

    .profile-details { display: flex; flex-direction: column; }
    .profile-name { font-size: 1.25rem; font-weight: 800; color: var(--text-dark); margin: 0; letter-spacing: -0.5px; }
    .profile-sub { font-size: 0.85rem; color: var(--text-muted); margin: 0; font-weight: 600; }

    .btn-close-minimal {
        background: #f8fafc;
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 12px;
        color: #94a3b8;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: all 0.2s;
    }
    .btn-close-minimal:hover { background: #fee2e2; color: #ef4444; }

    /* Modal Body Content */
    .modal-body-content {
        padding: 1.5rem 1.75rem 2rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .section-container { display: flex; flex-direction: column; gap: 1rem; }
    .section-header { display: flex; align-items: center; gap: 0.6rem; color: var(--primary-purple); font-size: 0.8rem; font-weight: 800; letter-spacing: 1px; }

    /* Content Area Styles */
    .empty-subjects-placeholder {
        background: #f8fafc;
        border: 2px dashed #e2e8f0;
        border-radius: var(--radius-md);
        padding: 2.5rem 1rem;
        text-align: center;
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .subject-chips-list { 
        display: flex; 
        flex-direction: column; 
        gap: 0.75rem; 
        max-height: 280px; 
        overflow-y: auto;
        padding-right: 4px;
    }
    .subject-chips-list::-webkit-scrollbar { width: 4px; }
    .subject-chips-list::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }

    .premium-subject-chip {
        background: #f8fafc;
        border-radius: 14px;
        padding: 0.75rem 0.85rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid #f1f5f9;
        transition: all 0.2s;
        gap: 0.5rem;
    }
    .premium-subject-chip:hover { transform: translateX(4px); background: white; border-color: #ede9fe; box-shadow: 0 4px 10px rgba(0,0,0,0.03); }

    .chip-main-content { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; min-width: 0; }
    .chip-row-top { display: flex; align-items: center; gap: 0.4rem; min-width: 0; }
    .chip-name { font-weight: 800; color: var(--text-dark); font-size: 0.88rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chip-code { background: #ede9fe; color: var(--primary-purple); font-size: 0.6rem; padding: 1px 6px; border-radius: 4px; font-weight: 800; flex-shrink: 0; }
    .chip-row-bottom { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
    .chip-time { font-size: 0.78rem; color: var(--text-muted); font-weight: 700; white-space: nowrap; }
    .chip-days { font-size: 0.74rem; color: var(--text-muted); font-weight: 600; opacity: 0.8; }

    .btn-chip-remove {
        background: #fee2e2;
        color: #ef4444;
        border: none;
        width: 30px;
        height: 30px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s;
    }
    .btn-chip-remove:hover { transform: rotate(90deg); background: #ef4444; color: white; }

    /* Form UI */
    .premium-form { display: flex; flex-direction: column; gap: 1.25rem; }
    .premium-field { display: flex; flex-direction: column; gap: 0.5rem; }
    .premium-field label { font-size: 0.75rem; font-weight: 800; color: var(--text-dark); letter-spacing: 0.5px; opacity: 0.8; }
    .premium-row { display: flex; gap: 1rem; }

    .premium-input {
        background: #f8fafc;
        border: 2px solid transparent;
        border-radius: var(--radius-md);
        padding: 0.85rem 1rem;
        font-size: 0.95rem;
        font-family: inherit;
        outline: none;
        transition: all 0.2s;
        width: 100%;
        box-sizing: border-box;
    }
    .premium-input:focus { background: white; border-color: var(--primary-purple); box-shadow: 0 8px 16px rgba(124, 58, 237, 0.08); }

    .subject-autocomplete { position: relative; }
    .search-inside-icon { position: absolute; right: 1rem; top: 1rem; color: #94a3b8; pointer-events: none; }

    .premium-dropdown {
        position: absolute;
        bottom: 100%; left: 0; right: 0;
        background: white;
        border-radius: var(--radius-md);
        margin-bottom: 8px;
        box-shadow: 0 -15px 35px rgba(0,0,0,0.15);
        z-index: 2500;
        max-height: 220px;
        overflow-y: auto;
        padding: 6px;
        border: 1px solid #f1f5f9;
    }

    .dropdown-row {
        padding: 0.85rem;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: background 0.2s;
    }
    .dropdown-row:hover, .dropdown-row.active { background: var(--soft-purple-bg); }
    .row-text { display: flex; align-items: center; gap: 0.5rem; }
    .row-code { font-size: 0.65rem; color: var(--text-muted); font-weight: 700; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; }
    .row-strand { font-size: 0.7rem; font-weight: 700; color: #4338ca; }

    .selection-pill {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: #ecfdf5;
        border: 1px solid #d1fae5;
        border-radius: 14px;
        padding: 0.5rem 0.85rem;
        margin-top: 0.5rem;
        color: #065f46;
        font-size: 0.88rem;
        font-weight: 700;
    }
    .selection-pill button { background: none; border: none; font-size: 1.25rem; color: #94a3b8; cursor: pointer; margin-left: auto; line-height: 1; }

    /* Day Picker Pill Buttons */
    .pill-day-picker { 
        display: flex; 
        flex-wrap: nowrap; 
        gap: 0.4rem; 
        overflow-x: hidden; 
        padding-bottom: 4px;
    }
    .pill-btn {
        flex: 1;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 8px 4px;
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s;
        font-family: inherit;
        white-space: nowrap;
        text-align: center;
    }
    .pill-btn.active { background: var(--primary-purple); border-color: var(--primary-purple); color: white; box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3); }

    /* Action Button (Gradient) */
    .btn-premium-action {
        background: linear-gradient(135deg, #4c1d95, #7c3aed);
        color: white;
        border: none;
        border-radius: var(--radius-md);
        padding: 1rem;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(124, 58, 237, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        font-family: inherit;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .btn-premium-action:hover:not(:disabled) { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(124, 58, 237, 0.3); }
    .btn-premium-action:active { transform: scale(0.97); }
    .btn-premium-action:disabled { opacity: 0.5; filter: grayscale(1); pointer-events: none; }

    /* Feedback - Deprecated in favor of Snackbar */
    .mini-loading { text-align: center; padding: 1rem; }
    .loader-sm { width: 22px; height: 22px; border: 3px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite; }
    .spinner-xl { width: 40px; height: 40px; border: 4px solid #f1f5f9; border-top-color: var(--primary-purple); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto; }

    /* Shimmer State */
    .loading-state { padding: 2rem 0; display: flex; flex-direction: column; gap: 1rem; }
    .shimmer-card { width: 100%; height: 80px; background: linear-gradient(90deg, #f1f5f9 25%, #f8fafc 50%, #f1f5f9 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 20px; }
    @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* Animations */
    @@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes scaleIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Confirm Modal */
    .confirm-modal { background: white; border-radius: 24px; padding: 2rem; width: 90%; max-width: 320px; text-align: center; box-shadow: var(--shadow-soft); z-index: 3000; }
    .confirm-icon { width: 56px; height: 56px; background: #fee2e2; color: #ef4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin: 0 auto 1.25rem; }
    .confirm-modal h4 { font-size: 1.25rem; font-weight: 800; color: var(--text-dark); margin: 0 0 0.5rem; }
    .confirm-modal p { font-size: 0.9rem; color: var(--text-muted); margin: 0 0 1.75rem; line-height: 1.5; }
    .confirm-actions { display: flex; gap: 0.75rem; }
    .btn-cancel { flex: 1; background: #f8fafc; border: 1.5px solid #e2e8f0; color: #64748b; padding: 0.8rem; border-radius: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .btn-confirm-remove { flex: 1; background: #ef4444; color: white; border: none; padding: 0.8rem; border-radius: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }

    /* Snackbar Design - Repositioned to Top */
    .snackbar-host {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%) translateY(-50px);
        z-index: 5000;
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        pointer-events: none;
        width: 90%;
        max-width: 360px;
    }
    .snackbar-host.active {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
        pointer-events: auto;
    }

    .snackbar-box {
        background: white;
        border-radius: 16px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        position: relative;
        overflow: hidden;
    }

    .snackbar-icon {
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .snackbar-message {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    .snackbar-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        background: rgba(0,0,0,0.1);
        width: 0%;
    }

    .snackbar-host.active .snackbar-progress {
        animation: snackbar-progress 3s linear forwards;
    }

    /* Types */
    .snackbar-host.success .snackbar-box { background: #ecfdf5; }
    .snackbar-host.success .snackbar-icon { color: #059669; }
    .snackbar-host.success .snackbar-progress { background: #10b981; }

    .snackbar-host.warning .snackbar-box { 
        background: #fffbeb; 
        animation: slideUpBounce 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .snackbar-host.warning .snackbar-icon { color: #d97706; }
    .snackbar-host.warning .snackbar-progress { background: #f59e0b; }

    .snackbar-host.error .snackbar-box { 
        background: #fef2f2; 
        animation: shake 0.4s ease-in-out;
    }
    .snackbar-host.error .snackbar-icon { color: #dc2626; }
    .snackbar-host.error .snackbar-progress { background: #ef4444; }

    @@keyframes snackbar-progress { from { width: 100%; } to { width: 0%; } }
    @@keyframes slideUpBounce {
        0% { transform: translateY(50px); opacity: 0; }
        60% { transform: translateY(-5px); }
        100% { transform: translateY(0); opacity: 1; }
    }
    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-8px); }
        40%, 80% { transform: translateX(8px); }
    }

    /* Custom Scrollbar */
    .modal-body-content::-webkit-scrollbar { width: 4px; }
    .modal-body-content::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
</style>

@code {
    private static readonly string[] AllDays = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" };

    private List<PendingTeacherInfo> advisors = new();
    private List<PendingTeacherInfo> filteredAdvisors => selectedGrade == null 
        ? advisors 
        : advisors.Where(a => a.GradeLevel == selectedGrade).ToList();
    private int? selectedGrade;
    private bool isLoading = true;
    private string? errorMessage;
    private string? headSchoolId;

    // Manage modal
    private bool showManageModal = false;
    private PendingTeacherInfo? selectedAdvisor;
    private List<ClassOffering> currentClasses = new();
    private bool isLoadingClasses = false;

    // Add form
    private string subjectSearchText = "";
    private string? selectedSubjectId;
    private bool showDropdown = false;
    private List<TeacherSubjectAssignment> allSubjectsForGrade = new();
    private List<TeacherSubjectAssignment> filteredSubjects = new();
    private HashSet<string> selectedDays = new(new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" });
    private string startTime = "07:30";
    private string endTime = "08:30";
    private bool isSaving = false;

    // Remove confirm
    private bool showRemoveConfirm = false;
    private ClassOffering? classToRemove;
    private bool isRemoving = false;

    // Snackbar state
    private bool showSnackbar = false;
    private string snackbarMessage = "";
    private string snackbarType = "success";
    private string snackbarIcon = "fas fa-check-circle";

    private async Task ShowSnackbar(string message, string type)
    {
        snackbarMessage = message;
        snackbarType = type;
        snackbarIcon = type switch
        {
            "success" => "fas fa-check-circle",
            "warning" => "fas fa-exclamation-triangle",
            "error" => "fas fa-times-circle",
            _ => "fas fa-info-circle"
        };
        showSnackbar = true;
        StateHasChanged();
        await Task.Delay(3000);
        showSnackbar = false;
        StateHasChanged();
    }

    private void FilterByGrade(int? grade)
    {
        selectedGrade = grade;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAdvisors();
    }

    private async Task LoadAdvisors()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var user = await AuthService.GetCurrentUserAsync();
            if (user == null)
            {
                errorMessage = "Could not get your account info.";
                return;
            }

            headSchoolId = user.SchoolId;
            if (string.IsNullOrEmpty(headSchoolId))
            {
                errorMessage = "Your account is not linked to a school.";
                return;
            }

            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var all = await http.GetFromJsonAsync<List<PendingTeacherInfo>>($"/api/teacher/all/{headSchoolId}");
            advisors = (all ?? new()).Where(t => t.UserType == "Advisor").ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OpenManageModal(PendingTeacherInfo advisor)
    {
        selectedAdvisor = advisor;
        showManageModal = true;
        subjectSearchText = "";
        selectedSubjectId = null;
        showDropdown = false;
        selectedDays = new HashSet<string>(AllDays);
        startTime = "07:30";
        endTime = "08:30";

        await LoadCurrentClasses();
        await LoadSubjectsForAdvisor();
        AutoAdjustStartTime();
    }

    private void CloseManageModal()
    {
        showManageModal = false;
        selectedAdvisor = null;
        currentClasses.Clear();
        allSubjectsForGrade.Clear();
        filteredSubjects.Clear();
    }

    private async Task LoadCurrentClasses()
    {
        if (selectedAdvisor?.TeacherId == null) return;
        isLoadingClasses = true;
        try
        {
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var list = await http.GetFromJsonAsync<List<ClassOffering>>($"/api/ClassOffering/advisor/{selectedAdvisor.TeacherId}");
            currentClasses = list ?? new();
        }
        catch { currentClasses = new(); }
        finally { isLoadingClasses = false; }
    }

    private async Task LoadSubjectsForAdvisor()
    {
        if (selectedAdvisor == null) return;
        int grade = selectedAdvisor.GradeLevel ?? 7;
        string? strand = string.IsNullOrEmpty(selectedAdvisor.Strand) ? null : selectedAdvisor.Strand;
        try
        {
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var strandParam = strand != null ? $"&strand={Uri.EscapeDataString(strand)}" : "";
            var list = await http.GetFromJsonAsync<List<TeacherSubjectAssignment>>(
                $"/api/ClassOffering/subjects-for-grade?gradeLevel={grade}{strandParam}");
            allSubjectsForGrade = list ?? new();
            var existingIds = currentClasses.Select(c => c.SubjectId).ToHashSet();
            filteredSubjects = allSubjectsForGrade.Where(s => !existingIds.Contains(s.SubjectId)).Take(10).ToList();
        }
        catch { allSubjectsForGrade = new(); filteredSubjects = new(); }
    }

    private async Task OnSubjectSearch(ChangeEventArgs e)
    {
        subjectSearchText = e.Value?.ToString() ?? "";
        showDropdown = true;
        var existingIds = currentClasses.Select(c => c.SubjectId).ToHashSet();

        if (string.IsNullOrWhiteSpace(subjectSearchText))
        {
            filteredSubjects = allSubjectsForGrade.Where(s => !existingIds.Contains(s.SubjectId)).Take(10).ToList();
        }
        else
        {
            filteredSubjects = allSubjectsForGrade
                .Where(s => !existingIds.Contains(s.SubjectId) &&
                            s.SubjectName.Contains(subjectSearchText, StringComparison.OrdinalIgnoreCase))
                .Take(10).ToList();

            if (filteredSubjects.Count < 3 && selectedAdvisor != null)
            {
                try
                {
                    var http = HttpClientFactory.CreateClient("AttrakAPI");
                    int grade = selectedAdvisor.GradeLevel ?? 7;
                    string? strand = string.IsNullOrEmpty(selectedAdvisor.Strand) ? null : selectedAdvisor.Strand;
                    var strandParam = strand != null ? $"&strand={Uri.EscapeDataString(strand)}" : "";
                    var extra = await http.GetFromJsonAsync<List<TeacherSubjectAssignment>>(
                        $"/api/ClassOffering/search-subjects?gradeLevel={grade}{strandParam}&keyword={Uri.EscapeDataString(subjectSearchText)}");
                    if (extra != null)
                        filteredSubjects.AddRange(extra.Where(s =>
                            !existingIds.Contains(s.SubjectId) &&
                            !filteredSubjects.Any(fs => fs.SubjectId == s.SubjectId)));
                }
                catch { }
            }
        }
    }

    private void SelectSubject(TeacherSubjectAssignment s)
    {
        selectedSubjectId = s.SubjectId;
        subjectSearchText = s.SubjectName;
        showDropdown = false;
        AutoAdjustStartTime();
    }

    private void ClearSubject()
    {
        selectedSubjectId = null;
        subjectSearchText = "";
        showDropdown = false;
        var existingIds = currentClasses.Select(c => c.SubjectId).ToHashSet();
        filteredSubjects = allSubjectsForGrade.Where(s => !existingIds.Contains(s.SubjectId)).Take(10).ToList();
    }

    private void ToggleDay(string day)
    {
        if (selectedDays.Contains(day))
        {
            if (selectedDays.Count > 1) selectedDays.Remove(day);
        }
        else
        {
            selectedDays.Add(day);
        }
        AutoAdjustStartTime();
    }

    private async Task AddSubject()
    {
        if (selectedAdvisor?.TeacherId == null)
        {
            _ = ShowSnackbar("Advisor profile not found.", "error");
            return;
        }
        if (string.IsNullOrEmpty(selectedSubjectId) && string.IsNullOrEmpty(subjectSearchText))
        {
            _ = ShowSnackbar("Please select a subject.", "error");
            return;
        }
        if (!TimeSpan.TryParse(startTime, out var tStart) || !TimeSpan.TryParse(endTime, out var tEnd) || tEnd <= tStart)
        {
            _ = ShowSnackbar("Invalid time range.", "error");
            return;
        }

        var dayStr = string.Join(",", selectedDays.OrderBy(d => Array.IndexOf(AllDays, d)));

        isSaving = true;
        try
        {
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var request = new CreateClassOfferingRequest
            {
                AdvisorId = selectedAdvisor.TeacherId,
                SubjectId = selectedSubjectId ?? "",
                SubjectName = string.IsNullOrEmpty(selectedSubjectId) ? subjectSearchText : null,
                GradeLevel = selectedAdvisor.GradeLevel ?? 7,
                Section = selectedAdvisor.Section ?? "",
                Strand = string.IsNullOrEmpty(selectedAdvisor.Strand) ? null : selectedAdvisor.Strand,
                ScheduleStart = tStart,
                ScheduleEnd = tEnd,
                DayOfWeek = dayStr
            };

            var response = await http.PostAsJsonAsync("/api/ClassOffering", request);
            if (response.IsSuccessStatusCode)
            {
                _ = ShowSnackbar("Subject added successfully!", "success");
                ClearSubject();
                selectedDays = new HashSet<string>(AllDays);
                startTime = "07:30";
                endTime = "08:30";
                await LoadCurrentClasses();
                await LoadSubjectsForAdvisor();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                _ = ShowSnackbar($"Failed to add: {err}", "error");
            }
        }
        catch (Exception ex)
        {
            _ = ShowSnackbar(ex.Message, "error");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OnStartTimeChange(ChangeEventArgs e)
    {
        startTime = e.Value?.ToString() ?? startTime;
        AutoAdjustStartTime();
    }

    private void OnEndTimeChange(ChangeEventArgs e)
    {
        endTime = e.Value?.ToString() ?? endTime;
        // Optional: ensure duration doesn't shrink to zero but mostly trust user
    }

    private void AutoAdjustStartTime()
    {
        if (!TimeSpan.TryParse(startTime, out var tStart) || !TimeSpan.TryParse(endTime, out var tEnd) || tEnd <= tStart)
            return;

        var duration = tEnd - tStart;
        bool adjusted = false;

        while (true)
        {
            var overlap = currentClasses.FirstOrDefault(c =>
                (c.DayOfWeek ?? "").Split(',').Any(d => selectedDays.Contains(d.Trim())) &&
                tStart < c.ScheduleEnd && tEnd > c.ScheduleStart);

            if (overlap == null) break;

            tStart = overlap.ScheduleEnd;
            tEnd = tStart + duration;
            adjusted = true;

            if (tStart >= TimeSpan.FromHours(22)) break;
        }

        if (adjusted)
        {
            startTime = tStart.ToString(@"hh\:mm");
            endTime = tEnd.ToString(@"hh\:mm");
            _ = ShowSnackbar("Time adjusted to avoid conflict.", "warning");
        }
    }

    private void ConfirmRemove(ClassOffering cls)
    {
        classToRemove = cls;
        showRemoveConfirm = true;
    }

    private async Task ExecuteRemove()
    {
        if (classToRemove == null || selectedAdvisor?.TeacherId == null) return;
        isRemoving = true;
        try
        {
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var response = await http.DeleteAsync(
                $"/api/ClassOffering/{classToRemove.ClassOfferingId}?advisorId={Uri.EscapeDataString(selectedAdvisor.TeacherId)}");
            if (response.IsSuccessStatusCode)
            {
                showRemoveConfirm = false;
                classToRemove = null;
                _ = ShowSnackbar("Subject removed.", "success");
                await LoadCurrentClasses();
                await LoadSubjectsForAdvisor();
            }
            else
            {
                _ = ShowSnackbar("Failed to remove subject.", "error");
                showRemoveConfirm = false;
            }
        }
        catch (Exception ex)
        {
            _ = ShowSnackbar(ex.Message, "error");
            showRemoveConfirm = false;
        }
        finally { isRemoving = false; }
    }

    private static string FormatDays(string dayOfWeek)
    {
        if (string.IsNullOrWhiteSpace(dayOfWeek)) return "";
        var days = dayOfWeek.Split(',').Select(d => d.Trim());
        return string.Join(", ", days.Select(d => d.Length >= 3 ? d.Substring(0, 3) : d));
    }
}
