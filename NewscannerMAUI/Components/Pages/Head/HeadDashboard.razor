@page "/head-dashboard"
@layout HeadLayout
@using NewscannerMAUI.Services
@using AttrackSharedClass.Models
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<div class="dashboard-container">
    <!-- Simplified Teacher Summary -->
    <div class="summary-section">
        <div class="section-header">
            <h3>Teacher Overview</h3>
            <div class="header-line"></div>
        </div>

        <div class="main-stats-card" @onclick="() => LoadTeacherList(false)">
            <div class="stat-item total">
                <span class="stat-label">Total Teachers</span>
                <span class="stat-value">@activeTeachers</span>
            </div>
        </div>

        <div class="detailed-stats-grid">
            <div class="detail-card success" @onclick="() => LoadTeacherList(false)">
                <div class="detail-icon head">
                    <i class="fas fa-user-check"></i>
                </div>
                <div class="detail-info">
                    <span class="detail-value">@withSubjectsCount</span>
                    <span class="detail-label">With Subjects</span>
                </div>
            </div>
            <div class="detail-card warning" @onclick="() => LoadTeacherList(true)">
                <div class="detail-icon alert">
                    <i class="fas fa-user-times"></i>
                </div>
                <div class="detail-info">
                    <span class="detail-value">@noSubjectsCount</span>
                    <span class="detail-label">No Subjects</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Dynamic Teacher List Section (Visible after click) -->
    @if (selectedTeacherList != null)
    {
        <div class="teacher-list-section">
            <div class="list-header">
                <h4>@(showingOnlyUnassigned ? "Unassigned Teachers" : "All Teachers")</h4>
                <button class="close-btn" @onclick="() => selectedTeacherList = null">&times;</button>
            </div>
            
            <div class="teacher-scroll-list">
                @foreach (var teacher in selectedTeacherList)
                {
                    <div class="teacher-info-card">
                        <div class="teacher-main">
                            <span class="teacher-name">@teacher.FullName</span>
                            <span class="teacher-role">@teacher.UserType</span>
                        </div>
                        <div class="teacher-details">
                            <i class="fas fa-book-open"></i>
                            <span class="subjects-text">@teacher.Subjects</span>
                        </div>
                        <div class="teacher-actions">
                            @if (teacher.OfferingCount == 0)
                            {
                                <button class="assign-btn" @onclick='() => Navigation.NavigateTo($"/head-subject-planner?teacherId={teacher.TeacherId}")'>
                                    Assign Subjects
                                </button>
                            }
                            else
                            {
                                <button class="view-btn" @onclick='() => Navigation.NavigateTo($"/head-subject-planner?teacherId={teacher.TeacherId}")'>
                                    Manage
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="tasks-section">
        <h3 class="tasks-title">Administrative Tasks</h3>
        <div class="task-grid">
            <div class="task-item" @onclick='() => Navigation.NavigateTo("/head-reports")'>
                <div class="task-icon reports">
                    <i class="fas fa-chart-line"></i>
                </div>
                <span>Reports</span>
            </div>
            <div class="task-item" @onclick="GoToApprovals">
                <div class="task-icon verify">
                    <i class="fas fa-check-double"></i>
                </div>
                <span>Verify</span>
            </div>
        </div>
    </div>
</div>

@code {
    private int activeTeachers = 0;
    private int noSubjectsCount = 0;
    private int withSubjectsCount = 0;
    private int pendingApprovals = 0;
    private string? currentSchoolId;

    private List<TeacherAssignmentInfo>? selectedTeacherList;
    private bool showingOnlyUnassigned = false;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user != null)
        {
            currentSchoolId = user.SchoolId;
            await LoadStats(currentSchoolId);
        }
    }

    private async Task LoadStats(string? schoolId)
    {
        if (string.IsNullOrEmpty(schoolId)) return;

        try
        {
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var stats = await http.GetFromJsonAsync<HeadStatsResponse>($"/api/teacher/head-stats/{schoolId}");
            if (stats != null)
            {
                activeTeachers = stats.ActiveTeachers;
                pendingApprovals = stats.PendingApprovals;
                noSubjectsCount = stats.NoSubjectsCount;
                withSubjectsCount = stats.WithSubjectsCount;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
    }

    private async Task LoadTeacherList(bool unassigned)
    {
        if (string.IsNullOrEmpty(currentSchoolId)) return;
        
        try
        {
            showingOnlyUnassigned = unassigned;
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            selectedTeacherList = await http.GetFromJsonAsync<List<TeacherAssignmentInfo>>($"/api/teacher/assignments/{currentSchoolId}?onlyUnassigned={unassigned}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading teacher list: {ex.Message}");
        }
    }

    private void GoToApprovals() => Navigation.NavigateTo("/head/teacher-approvals");

    private class HeadStatsResponse
    {
        public int ActiveTeachers { get; set; }
        public int PendingApprovals { get; set; }
        public int NoSubjectsCount { get; set; }
        public int WithSubjectsCount { get; set; }
    }

    private class TeacherAssignmentInfo
    {
        public string TeacherId { get; set; } = "";
        public string FullName { get; set; } = "";
        public string UserType { get; set; } = "";
        public int OfferingCount { get; set; }
        public string Subjects { get; set; } = "";
    }
}

<style>
    .dashboard-container {
        padding: 1.5rem;
        background: #f8faff;
        min-height: 100vh;
        max-width: 500px;
        margin: 0 auto;
    }

    .summary-section {
        margin-bottom: 2rem;
    }

    .section-header {
        margin-bottom: 1.5rem;
    }

    .section-header h3 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #2b166b;
        margin: 0;
    }

    .header-line {
        width: 40px;
        height: 4px;
        background: #6366f1;
        border-radius: 10px;
        margin-top: 8px;
    }

    .main-stats-card {
        background: white;
        border-radius: 24px;
        padding: 2.5rem;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 10px 30px rgba(43, 22, 107, 0.05);
        margin-bottom: 1rem;
        border: 1px solid #edf2f7;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .main-stats-card:active { transform: scale(0.98); }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .stat-label {
        color: #718096;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 3.5rem;
        font-weight: 900;
        color: #2b166b;
        line-height: 1;
    }

    .detailed-stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .detail-card {
        background: white;
        padding: 1.25rem;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 1rem;
        border: 1px solid #edf2f7;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        cursor: pointer;
        transition: transform 0.2s;
    }

    .detail-card:active { transform: scale(0.96); }

    .detail-card.success { border-left: 4px solid #10b981; }
    .detail-card.warning { border-left: 4px solid #f59e0b; }

    .detail-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .success .detail-icon { background: rgba(16, 185, 129, 0.1); color: #10b981; }
    .warning .detail-icon { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }

    .detail-value {
        display: block;
        font-weight: 800;
        color: #2d3748;
        font-size: 1.25rem;
    }

    .detail-label {
        font-size: 0.75rem;
        color: #718096;
        font-weight: 600;
    }

    /* Teacher List Section */
    .teacher-list-section {
        background: white;
        border-radius: 24px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #edf2f7;
        animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .list-header h4 {
        margin: 0;
        font-weight: 800;
        color: #2b166b;
    }

    .close-btn {
        background: #f1f5f9;
        border: none;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1.25rem;
        color: #64748b;
    }

    .teacher-scroll-list {
        max-height: 400px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding-right: 5px;
    }

    .teacher-scroll-list::-webkit-scrollbar { width: 4px; }
    .teacher-scroll-list::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }

    .teacher-info-card {
        padding: 1rem;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #f1f5f9;
    }

    .teacher-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .teacher-name {
        font-weight: 800;
        color: #1e293b;
        font-size: 0.95rem;
    }

    .teacher-role {
        font-size: 0.7rem;
        font-weight: 700;
        color: #6366f1;
        background: rgba(99, 102, 241, 0.1);
        padding: 2px 8px;
        border-radius: 20px;
    }

    .teacher-details {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        color: #64748b;
        font-size: 0.8rem;
        margin-bottom: 0.75rem;
    }

    .teacher-details i { margin-top: 2px; font-size: 0.75rem; }

    .subjects-text {
        line-height: 1.4;
        font-weight: 500;
    }

    .teacher-actions {
        display: flex;
        justify-content: flex-end;
    }

    .assign-btn, .view-btn {
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: transform 0.1s;
    }

    .assign-btn {
        background: #f59e0b;
        color: white;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
    }

    .view-btn {
        background: #f1f5f9;
        color: #475569;
    }

    .assign-btn:active { transform: scale(0.95); }

    /* Tasks Section */
    .tasks-section {
        background: white;
        padding: 1.5rem;
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    .tasks-title {
        font-size: 1rem;
        font-weight: 700;
        color: #718096;
        margin-bottom: 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .task-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .task-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
    }

    .task-icon {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .task-item:active .task-icon { transform: scale(0.95); }

    .task-icon.reports { background: #ebf8ff; color: #3182ce; }
    .task-icon.verify { background: #f0fff4; color: #38a169; }

    .task-item span {
        font-size: 0.85rem;
        font-weight: 700;
        color: #4a5568;
    }
</style>
