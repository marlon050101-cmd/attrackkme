@page "/head/teacher-approvals"
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@layout HeadLayout
@inject IHttpClientFactory HttpClientFactory
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="approvals-container">
    <div class="page-header">
        <div class="header-icon">
            <i class="fas fa-user-plus"></i>
        </div>
        <div class="header-text">
            <h1>Assign Teacher</h1>
            <p>Select role and authorize access</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="shimmer-card"></div>
            <div class="shimmer-card"></div>
            <p>Authenticating pending requests...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-panel">
            <div class="error-icon"><i class="fas fa-circle-exclamation"></i></div>
            <div class="error-content">
                <strong>Connection Error</strong>
                <p>@errorMessage</p>
            </div>
            <button class="btn-retry" @onclick="LoadPendingTeachers">Try Again</button>
        </div>
    }
    else if (userSchoolId == null)
    {
        <div class="empty-state glass">
            <div class="empty-icon"><i class="fas fa-school-circle-exclamation"></i></div>
            <h3>Principal Profile Required</h3>
            <p>Your account must be linked to a school to manage staff. Please contact the district administrator.</p>
        </div>
    }
    else if (pendingTeachers == null || !pendingTeachers.Any())
    {
        <div class="empty-state glass">
            <div class="empty-icon-success"><i class="fas fa-certificate"></i></div>
            <h3>Everything is in Order</h3>
            <p>All registration requests for <strong>SARDO-TRACKCARE</strong> are cleared. You are currently up to date.</p>
            <button class="btn-ghost" @onclick="LoadPendingTeachers">
                <i class="fas fa-rotate"></i> Refresh Dashboard
            </button>
        </div>
    }
    else
    {
        <div class="approvals-list">
            <div class="list-meta">
                <span><i class="fas fa-user-clock"></i> @pendingTeachers.Count Requesting Access</span>
            </div>
            @foreach (var teacher in pendingTeachers)
            {
                <div class="assign-card glass-hover fade-in">
                    <div class="teacher-meta">
                        <div class="teacher-avatar-compact">
                            @teacher.FullName.Substring(0, 1).ToUpper()
                        </div>
                        <h3 class="name-only">@teacher.FullName</h3>
                    </div>
                    
                    <button class="btn-assign-main" @onclick="() => OpenRoleModal(teacher)" disabled="@isProcessing">
                        @if (processingId == teacher.UserId)
                        {
                            <div class="spinner-sm"></div>
                        }
                        else
                        {
                            <span>Assign</span>
                        }
                    </button>
                </div>
            }
        </div>
    }
</div>

@if (showRoleModal && teacherToAssign != null)
{
    <div class="modal-overlay">
        <div class="role-modal fade-in">
            <div class="modal-header">
                <div class="teacher-focus-avatar">
                    @teacherToAssign.FullName.Substring(0, 1).ToUpper()
                </div>
                <h3>Assign Role</h3>
                <p>Select role for <strong>@teacherToAssign.FullName</strong></p>
            </div>
            
            <div class="role-selection-grid">
                <button class="role-option-card" @onclick="() => ApproveTeacher(teacherToAssign, UserType.SubjectTeacher)">
                    <div class="role-icon teacher"><i class="fas fa-book"></i></div>
                    <div class="role-info">
                        <strong>Subject Teacher</strong>
                        <span>Manage subjects and student grades</span>
                    </div>
                </button>

                <button class="role-option-card" @onclick="() => ApproveTeacher(teacherToAssign, UserType.Advisor)">
                    <div class="role-icon advisor"><i class="fas fa-user-tie"></i></div>
                    <div class="role-info">
                        <strong>Class Advisor</strong>
                        <span>Manage sections and student attendance</span>
                    </div>
                </button>
            </div>

            <button class="btn-cancel-modal" @onclick="CloseRoleModal">Cancel</button>
        </div>
    </div>
}

@if (showSuccessModal)
{
    <div class="modal-overlay">
        <div class="success-modal scale-in">
            <div class="success-icon">
                <i class="fas fa-user-check"></i>
            </div>
            <h3>Teacher Approved!</h3>
            <p>Access has been granted to <strong>@lastApprovedName</strong>. They can now log in to the portal.</p>
            <button class="btn-done" @onclick="() => showSuccessModal = false">Continue</button>
        </div>
    </div>
}

<style>
    .approvals-container {
        padding: 2rem 1.5rem;
        max-width: 500px;
        margin: 0 auto;
        font-family: 'Outfit', sans-serif;
    }

    .page-header {
        margin-bottom: 2.5rem;
        text-align: left;
    }

    .header-text h1 {
        font-size: 2.4rem;
        font-weight: 900;
        color: #0f172a;
        margin: 0;
        letter-spacing: -1.5px;
    }

    .header-text p {
        color: #64748b;
        margin-top: 0.2rem;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .list-meta {
        margin-bottom: 1.5rem;
        font-size: 0.8rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .assign-card {
        background: white;
        border: 1px solid #f1f5f9;
        border-radius: 20px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .assign-card:hover {
        border-color: #cbd5e1;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    }

    .teacher-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
        min-width: 0;
    }

    .teacher-avatar-compact {
        width: 40px;
        height: 40px;
        background: #f1f5f9;
        color: #4c1d95;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1rem;
    }

    .name-only {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
        white-space: normal; /* Wrapped to show full name */
        word-break: break-word;
        line-height: 1.3;
    }

    .btn-assign-main {
        background: #0f172a;
        color: white;
        border: none;
        padding: 0.6rem 1.5rem;
        border-radius: 14px;
        font-weight: 800;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .btn-assign-main:hover:not(:disabled) {
        background: #334155;
        transform: scale(1.05);
    }

    /* Role Modal Styling */
    .role-modal {
        background: white;
        padding: 2rem;
        border-radius: 32px;
        width: 95%;
        max-width: 400px;
        position: relative;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .modal-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .teacher-focus-avatar {
        width: 64px;
        height: 64px;
        background: #4c1d95;
        color: white;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 900;
        margin: 0 auto 1rem;
    }

    .modal-header h3 {
        font-size: 1.5rem;
        font-weight: 900;
        color: #0f172a;
        margin: 0;
    }

    .modal-header p {
        color: #64748b;
        margin: 0.5rem 0 0;
        font-size: 0.9rem;
    }

    .role-selection-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .role-option-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem;
        background: #f8fafc;
        border: 2px solid #f1f5f9;
        border-radius: 20px;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s ease;
        width: 100%;
    }

    .role-option-card:hover {
        background: white;
        border-color: #4c1d95;
        transform: translateX(4px);
    }

    .role-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .role-icon.teacher { background: #e0e7ff; color: #4338ca; }
    .role-icon.advisor { background: #fef3c7; color: #d97706; }

    .role-info {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .role-info strong {
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
    }

    .role-info span {
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 600;
    }

    .btn-cancel-modal {
        width: 100%;
        background: transparent;
        border: 2px solid #f1f5f9;
        padding: 0.75rem;
        border-radius: 16px;
        color: #94a3b8;
        font-weight: 800;
        font-size: 0.9rem;
        cursor: pointer;
    }

    .btn-cancel-modal:hover {
        background: #f8fafc;
        color: #64748b;
        border-color: #cbd5e1;
    }

    /* Success Modal */
    .success-modal {
        background: white;
        padding: 2.5rem 2rem;
        border-radius: 32px;
        text-align: center;
        width: 90%;
        max-width: 340px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .success-icon {
        width: 72px;
        height: 72px;
        background: #10b981;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.5rem;
        box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3);
    }

    .btn-done {
        width: 100%;
        margin-top: 2rem;
        padding: 1rem;
        background: #0f172a;
        color: white;
        border: none;
        border-radius: 16px;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    /* Shared Modal Logic */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 1rem;
    }

    /* Utility */
    .fade-in { animation: fadeIn 0.4s ease-out; }
    .scale-in { animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes scaleIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

    .spinner-sm {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<PendingTeacherInfo>? pendingTeachers;
    private bool isLoading = true;
    private bool isProcessing = false;
    private string? processingId;
    
    private bool showRoleModal = false;
    private PendingTeacherInfo? teacherToAssign;
    
    private bool showSuccessModal = false;
    private string lastApprovedName = "";
    private string? userSchoolId;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingTeachers();
    }

    private async Task LoadPendingTeachers()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null)
            {
                userSchoolId = user.SchoolId;
                if (!string.IsNullOrEmpty(userSchoolId))
                {
                    var http = HttpClientFactory.CreateClient("AttrakAPI");
                    pendingTeachers = await http.GetFromJsonAsync<List<PendingTeacherInfo>>($"/api/teacher/pending/{userSchoolId}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pending teachers: {ex.Message}");
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenRoleModal(PendingTeacherInfo teacher)
    {
        teacherToAssign = teacher;
        showRoleModal = true;
    }

    private void CloseRoleModal()
    {
        showRoleModal = false;
        teacherToAssign = null;
    }

    private async Task ApproveTeacher(PendingTeacherInfo teacher, UserType role)
    {
        if (isProcessing) return;

        try
        {
            isProcessing = true;
            processingId = teacher.UserId;
            showRoleModal = false; // Hide role modal immediately
            
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var response = await http.PutAsync($"/api/teacher/approve/{teacher.UserId}?role={role}", null);
            if (response.IsSuccessStatusCode)
            {
                lastApprovedName = teacher.FullName;
                showSuccessModal = true;
                pendingTeachers?.Remove(teacher);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error approving teacher: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            processingId = null;
            teacherToAssign = null;
        }
    }
}
