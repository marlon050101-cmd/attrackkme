@page "/head/teacher-approvals"
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@layout HeadLayout
@inject IHttpClientFactory HttpClientFactory
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="approvals-container">
    <div class="page-header">
        <div class="header-icon">
            <i class="fas fa-user-shield"></i>
        </div>
        <div class="header-text">
            <h1>Verification Center</h1>
            <p>Review and approve pending teacher registrations</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Fetching pending requests...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-notification" style="background: #fff5f5; border: 1px solid #feb2b2; padding: 1rem; border-radius: 12px; color: #c53030; margin-bottom: 1.5rem;">
            <i class="fas fa-exclamation-circle"></i> <strong>Error:</strong> @errorMessage
            <button class="btn-refresh" @onclick="LoadPendingTeachers" style="margin-top: 0.5rem; display: block; padding: 0.4rem 0.8rem;">Try Again</button>
        </div>
    }
    else if (userSchoolId == null)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3>Profile Incomplete</h3>
            <p>Your account is not linked to a school. Please update your profile or contact support.</p>
        </div>
    }
    else if (pendingTeachers == null || !pendingTeachers.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h3>All Caught Up!</h3>
            <p>There are no pending teacher approvals for your school at this moment.</p>
            <div class="debug-info" style="font-size: 0.7rem; color: #a0aec0; margin-top: 1rem;">
                School ID: @userSchoolId
            </div>
            <button class="btn-refresh" @onclick="LoadPendingTeachers">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>
    }
    else
    {
        <div class="approvals-list">
            @foreach (var teacher in pendingTeachers)
            {
                <div class="approval-card">
                    <div class="card-accent"></div>
                    <div class="teacher-info">
                        <div class="teacher-avatar">
                            @teacher.FullName.Substring(0, 1).ToUpper()
                        </div>
                        <div class="details">
                            <span class="name">@teacher.FullName</span>
                            <span class="email">@teacher.Email</span>
                            <div class="meta">
                                <span class="badge-role">@teacher.UserType</span>
                                <span class="date"><i class="far fa-clock"></i> Registered @teacher.RegisteredAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <div class="actions">
                        <button class="btn-approve" @onclick="() => ApproveTeacher(teacher)" disabled="@isProcessing">
                            @if (processingId == teacher.UserId)
                            {
                                <span class="spinner-sm"></span>
                            }
                            else
                            {
                                <i class="fas fa-check"></i>
                                <span>Approve Access</span>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showSuccessModal)
{
    <div class="modal-overlay">
        <div class="success-modal">
            <div class="success-icon">
                <i class="fas fa-user-check"></i>
            </div>
            <h3>Teacher Approved!</h3>
            <p>Access has been granted to <strong>@lastApprovedName</strong>. They can now log in to the portal.</p>
            <button class="btn-done" @onclick="() => showSuccessModal = false">Continue</button>
        </div>
    </div>
}

<style>
    .approvals-container {
        padding: 1.5rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 2.5rem;
        animation: fadeInDown 0.5s ease-out;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #6f42c1 0%, #4b2ea2 100%);
        color: white;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        box-shadow: 0 10px 20px rgba(111, 66, 193, 0.2);
    }

    .header-text h1 {
        font-size: 1.75rem;
        font-weight: 900;
        color: #2b166b;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .header-text p {
        color: #6f42c1;
        margin: 0;
        font-weight: 600;
        font-size: 0.95rem;
    }

    /* List & Cards */
    .approvals-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .approval-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #edf2f7;
        position: relative;
        overflow: hidden;
        animation: slideInUp 0.4s ease-out;
    }

    .card-accent {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(to right, #6f42c1, #f6c23e);
    }

    .teacher-info {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .teacher-avatar {
        width: 50px;
        height: 50px;
        background: #f1f0f7;
        color: #6f42c1;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.25rem;
        border: 2px solid white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .details {
        display: flex;
        flex-direction: column;
    }

    .details .name {
        font-weight: 800;
        font-size: 1.1rem;
        color: #2b166b;
    }

    .details .email {
        font-size: 0.85rem;
        color: #718096;
        margin-bottom: 0.4rem;
    }

    .meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .badge-role {
        background: rgba(111, 66, 193, 0.1);
        color: #6f42c1;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .date {
        font-size: 0.75rem;
        color: #a0aec0;
    }

    /* Actions */
    .btn-approve {
        background: linear-gradient(135deg, #6f42c1 0%, #4b2ea2 100%);
        color: white;
        border: none;
        padding: 0.8rem 1.5rem;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 8px 20px rgba(111, 66, 193, 0.25);
    }

    .btn-approve:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(111, 66, 193, 0.35);
    }

    .btn-approve:active {
        transform: scale(0.95);
    }

    /* States */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 30px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.03);
    }

    .empty-icon {
        font-size: 4rem;
        color: #6f42c1;
        opacity: 0.2;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-weight: 800;
        color: #2d3748;
    }

    .btn-refresh {
        margin-top: 1.5rem;
        background: none;
        border: 1px solid #e2e8f0;
        padding: 0.6rem 1.2rem;
        border-radius: 12px;
        color: #718096;
        font-weight: 700;
        cursor: pointer;
    }

    .loading-state {
        text-align: center;
        padding: 3rem;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #6f42c1;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }

    .spinner-sm {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top: 2px solid white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(43, 22, 107, 0.4);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }

    .success-modal {
        background: white;
        padding: 2.5rem;
        border-radius: 30px;
        text-align: center;
        max-width: 400px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.2);
        animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: #f1f0f7;
        color: #6f42c1;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 1.5rem;
    }

    .btn-done {
        width: 100%;
        margin-top: 1.5rem;
        padding: 1rem;
        background: #6f42c1;
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 800;
        cursor: pointer;
    }

    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    @@keyframes popIn { 0% { opacity: 0; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }
</style>

@code {
    private List<PendingTeacherInfo>? pendingTeachers;
    private bool isLoading = true;
    private bool isProcessing = false;
    private string? processingId;
    private bool showSuccessModal = false;
    private string lastApprovedName = "";
    private string? userSchoolId;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingTeachers();
    }

    private async Task LoadPendingTeachers()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null)
            {
                userSchoolId = user.SchoolId;
                if (!string.IsNullOrEmpty(userSchoolId))
                {
                    var http = HttpClientFactory.CreateClient("AttrakAPI");
                    pendingTeachers = await http.GetFromJsonAsync<List<PendingTeacherInfo>>($"/api/teacher/pending/{userSchoolId}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pending teachers: {ex.Message}");
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApproveTeacher(PendingTeacherInfo teacher)
    {
        if (isProcessing) return;

        try
        {
            isProcessing = true;
            processingId = teacher.UserId;
            
            var http = HttpClientFactory.CreateClient("AttrakAPI");
            var response = await http.PutAsync($"/api/teacher/approve/{teacher.UserId}", null);
            if (response.IsSuccessStatusCode)
            {
                lastApprovedName = teacher.FullName;
                showSuccessModal = true;
                pendingTeachers?.Remove(teacher);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error approving teacher: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            processingId = null;
        }
    }
}
