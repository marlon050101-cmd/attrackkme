@page "/kiosk/student-registration"
@layout KioskLayout
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject AuthService AuthService
@inject OfflineDataService OfflineDataService
@inject HybridQRValidationService HybridQRValidationService
@using Microsoft.Maui.Media

<div class="kiosk-container" @onclick="EnsureInputFocus">
    @if (isLoading)
    {
        <div class="glass-card loading-view animate-slide-up">
            <div class="text-center p-4">
                <span class="spinner"><i class="fas fa-spinner fa-spin fa-3x spinner-icon"></i></span>
                <h3 class="mt-4">Loading Data...</h3>
            </div>
        </div>
    }
    else if (selectedSubject != null)
    {
        <div class="glass-card scanner-active animate-slide-up">
            <div class="scanner-header">
                <div class="scanner-header-title">
                    <i class="fas fa-barcode"></i> ACTIVE SCANNER
                </div>
                <button class="btn-cancel" @onclick="EndSession">
                    <i class="fas fa-times"></i> End Session
                </button>
            </div>
            
            <div class="scanner-info-banner">
                <h2 class="subject-title">@selectedSubject.SubjectName</h2>
                <p class="subject-details">
                    <i class="fas fa-clock"></i> @FormatTimeSpan(selectedSubject.ScheduleStart) - @FormatTimeSpan(selectedSubject.ScheduleEnd) &nbsp; &bull; &nbsp; <i class="fas fa-users"></i> @selectedSubject.Section
                </p>
                @if(selectedSubject.GradeLevel >= 11 && !string.IsNullOrEmpty(selectedSubject.Strand))
                {
                    <p class="subject-strand">Strand: @selectedSubject.Strand</p>
                }
            </div>

            @if (isProcessing)
            {
                <div class="status-banner processing">
                    <i class="fas fa-spinner fa-spin"></i> Processing Scan...
                </div>
            }
            else if (showFeedback)
            {
                <div class="feedback-container animate-scale-in">
                    <div class="status-banner @(feedbackSuccess ? "success" : "error")">
                        <i class="fas @(feedbackSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i> @feedbackMessage
                    </div>
                    @if (feedbackSuccess && !string.IsNullOrEmpty(scannedStudentName))
                    {
                        <div class="student-name-display animate-slide-up">
                            <span class="name-label">STUDENT</span>
                            <h1 class="student-name">@scannedStudentName</h1>
                            <div class="attendance-label mt-2">
                                <span class="badge bg-success"><i class="fas fa-check-double me-1"></i> SUBJECT ATTENDANCE RECORDED</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="status-banner ready pulse-border">
                    <i class="fas fa-qrcode"></i> Ready: Scan a Student ID Barcode
                </div>
            }

            <div class="recent-scans">
                <h4 style="color: white; margin-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                    <i class="fas fa-history text-info"></i> Recent Scans Pipeline
                </h4>
                @if (!recentScans.Any())
                {
                    <p style="color: #94a3b8; text-align: center; padding: 20px; font-style: italic;">No students scanned yet in this active session.</p>
                }
                else
                {
                    <div class="scan-list">
                        @foreach (var scan in recentScans)
                        {
                            <div class="scan-item @(scan.Success ? "success-border" : "error-border")">
                                <div class="scan-time">@scan.Time.ToString("hh:mm:ss tt")</div>
                                <div class="scan-name">@scan.Name</div>
                                <div class="scan-status @(scan.Success ? "text-success" : "text-danger")">
                                    <i class="fas @(scan.Success ? "fa-check" : "fa-times")"></i> @scan.Status
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Hidden input for Barcode Scanner Wedge -->
            <input @ref="hiddenScannerInput" 
                   @bind="hiddenInputBuffer" 
                   @bind:event="oninput" 
                   @onkeyup="HandleKeyPress" 
                   class="hidden-input" 
                   autocomplete="off" />
        </div>
    }
    else
    {
        <div class="glass-card animate-slide-up">
            <div class="header">
                <div class="header-icon">
                    <i class="fas fa-chalkboard-teacher"></i>
                </div>
                <h2>Subject Scanner Kiosk</h2>
                <p>Welcome! Setup your scanner below to track attendance.</p>
            </div>

            @if (isHeadUser)
            {
                <!-- HEAD USER UI PATH -->
                <div class="head-filter-container">
                    @if (!availableGrades.Any() && !isLoading)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-calendar-times me-2"></i>
                            No classes found for <strong>@todayString</strong>. 
                            <br/><small>Please ensure subjects are scheduled for today in the Subject Planner.</small>
                        </div>
                        <button class="btn btn-outline-primary mt-3" @onclick="LoadRoleAndSubjects">
                            <i class="fas fa-sync me-2"></i>Retry Loading
                        </button>
                    }
                    else
                    {
                        <div class="filter-dropdown-group">
                            <div class="dropdown-wrapper">
                                <label>Grade Level</label>
                                <select class="modern-select" value="@selectedGrade" @onchange="OnGradeChanged">
                                    <option value="">-- Select Grade --</option>
                                    @foreach (var grade in availableGrades)
                                    {
                                        <option value="@grade">Grade @grade</option>
                                    }
                                </select>
                            </div>

                            @if (selectedGrade >= 11 && availableStrands.Any())
                            {
                                <div class="dropdown-wrapper animate-scale-in">
                                    <label>Strand</label>
                                    <select class="modern-select" value="@selectedStrand" @onchange="OnStrandChanged">
                                        <option value="">-- Select Strand --</option>
                                        @foreach (var strand in availableStrands)
                                        {
                                            <option value="@strand">@strand</option>
                                        }
                                    </select>
                                </div>
                            }

                            @if (selectedGrade != null && (selectedGrade < 11 || !availableStrands.Any() || !string.IsNullOrEmpty(selectedStrand)))
                            {
                                <div class="dropdown-wrapper animate-scale-in">
                                    <label>Section</label>
                                    <select class="modern-select" value="@selectedSection" @onchange="OnSectionChanged">
                                        <option value="">-- Select Section --</option>
                                        @foreach (var sec in availableSections)
                                        {
                                            <option value="@sec">@sec</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(selectedSection))
                        {
                            <h3 class="filter-title mt-4">Available Subjects</h3>
                            @if (!filteredSubjects.Any())
                            {
                                <div class="error-banner mt-3 animate-scale-in">
                                    <i class="fas fa-info-circle"></i> No subjects assigned for this section today.
                                </div>
                            }
                            else
                            {
                                <div class="subject-grid mt-3 animate-slide-up">
                                    @foreach (var cls in filteredSubjects)
                                    {
                                        <div class="subject-card" @onclick="() => SelectSubject(cls)">
                                            <h3>@cls.SubjectName</h3>
                                            <p><i class="fas fa-clock text-info"></i> @FormatTimeSpan(cls.ScheduleStart) - @FormatTimeSpan(cls.ScheduleEnd)</p>
                                            <p><i class="fas fa-user-tie text-warning"></i> Teacher: @cls.TeacherId</p>
                                            <span class="badge-active">Select <i class="fas fa-arrow-right"></i></span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            }
            else
            {
                <!-- TEACHER USER UI PATH (Standard) -->
                @if (teacherClasses == null || !teacherClasses.Any())
                {
                    <div class="error-banner">
                        <i class="fas fa-info-circle"></i> No subjects assigned for today. Please contact the administrator if this is a mistake.
                    </div>
                }
                else
                {
                    <h3 class="filter-title">Select your Subject to start scanning</h3>
                    <div class="subject-grid mt-3">
                        @foreach (var cls in teacherClasses)
                        {
                            <div class="subject-card" @onclick="() => SelectSubject(cls)">
                                <h3>@cls.SubjectName</h3>
                                <p><i class="fas fa-clock text-info"></i> @FormatTimeSpan(cls.ScheduleStart) - @FormatTimeSpan(cls.ScheduleEnd)</p>
                                <p><i class="fas fa-users text-warning"></i> Sec: @cls.Section | Gr: @cls.GradeLevel</p>
                                @if(cls.GradeLevel >= 11 && !string.IsNullOrEmpty(cls.Strand))
                                {
                                    <p><i class="fas fa-layer-group text-success"></i> Strand: @cls.Strand</p>
                                }
                                <span class="badge-active">Select <i class="fas fa-arrow-right"></i></span>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private List<ClassOffering> allSchoolClasses = new(); // For Head
    private List<ClassOffering> teacherClasses = new();   // For Teacher
    private List<ClassOffering> filteredSubjects = new(); // Results from filtering
    private ClassOffering? selectedSubject;
    private bool isLoading = true;
    private bool isHeadUser = false;
    private string currentUserId = "";
    private string currentSchoolId = "";
    private string todayString = ""; // Added for UI display

    // Head Filter States
    private int? selectedGrade = null;
    private string selectedStrand = "";
    private string selectedSection = "";

    private List<int> availableGrades = new();
    private List<string> availableStrands = new();
    private List<string> availableSections = new();

    // Scanner state
    private string hiddenInputBuffer = "";
    private ElementReference hiddenScannerInput;
    private bool isProcessing = false;
    private bool showFeedback = false;
    private bool feedbackSuccess = false;
    private string feedbackMessage = "";
    private string scannedStudentName = ""; // Added to show name prominently

    // Active session logs
    private List<ScanRecord> recentScans = new();

    private class ScanRecord
    {
        public string Name { get; set; } = "";
        public DateTime Time { get; set; }
        public bool Success { get; set; }
        public string Status { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRoleAndSubjects();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (selectedSubject != null)
        {
            try { await hiddenScannerInput.FocusAsync(); } catch { }
        }
    }

    private async Task LoadRoleAndSubjects()
    {
        isLoading = true;
        try
        {
            var currentUser = await AuthService.GetCurrentUserAsync();
            if (currentUser != null)
            {
                currentUserId = currentUser.TeacherId ?? currentUser.UserId;
                currentSchoolId = currentUser.SchoolId ?? "";
                isHeadUser = currentUser.UserType == UserType.Head || currentUser.UserType == UserType.Admin;
                
                var httpClient = HttpClientFactory.CreateClient("AttrakAPI");
                todayString = DateTime.Now.DayOfWeek.ToString(); // Assign to class member

                if (isHeadUser)
                {
                    // Head: Fetch all classes for the school
                    List<ClassOffering>? result = null;
                    try 
                    {
                        // FIXED: Added /all to the endpoint
                        result = await httpClient.GetFromJsonAsync<List<ClassOffering>>($"api/ClassOffering/all?schoolId={currentSchoolId}");
                    }
                    catch (Exception ex)
                    {
                        System.Diagnostics.Debug.WriteLine($"Error fetching all school classes: {ex.Message}");
                    }

                    allSchoolClasses = result?.Where(c => c.DayOfWeek.Contains(todayString, StringComparison.OrdinalIgnoreCase)).ToList() ?? new();
                    
                    // Extract unique available grades from today's active classes
                    availableGrades = allSchoolClasses.Select(c => c.GradeLevel).Distinct().OrderBy(g => g).ToList();
                }
                else
                {
                    // Teacher/Adviser: Fetch their assigned classes
                    List<ClassOffering>? result = null;
                    try 
                    {
                        result = await httpClient.GetFromJsonAsync<List<ClassOffering>>($"api/ClassOffering/teacher/{currentUserId}");
                    }
                    catch (Exception)
                    {
                        result = await OfflineDataService.GetClassOfferingsOfflineAsync(currentUserId);
                    }

                    teacherClasses = result?.Where(c => c.DayOfWeek.Contains(todayString, StringComparison.OrdinalIgnoreCase)).ToList() ?? new();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading subjects: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // Filter Logic for Head User
    private void SelectGrade(int grade)
    {
        selectedGrade = grade;
        selectedStrand = "";
        selectedSection = "";
        
        var gradeClasses = allSchoolClasses.Where(c => c.GradeLevel == grade).ToList();

        if (grade >= 11)
        {
            availableStrands = gradeClasses.Where(c => !string.IsNullOrEmpty(c.Strand))
                                            .Select(c => c.Strand)
                                            .Distinct()
                                            .OrderBy(s => s)
                                            .ToList();
            
            // Fallback: If no strands are defined for this Grade 11/12, jump straight to sections
            if (!availableStrands.Any())
            {
                selectedStrand = "N/A";
                availableSections = gradeClasses.Select(c => c.Section).Distinct().OrderBy(s => s).ToList();
            }
        }
        else
        {
            availableSections = gradeClasses.Select(c => c.Section).Distinct().OrderBy(s => s).ToList();
        }
        StateHasChanged();
    }

    private void SelectStrand(string strand)
    {
        selectedStrand = strand;
        selectedSection = "";
        availableSections = allSchoolClasses.Where(c => c.GradeLevel == selectedGrade && c.Strand == strand)
                                            .Select(c => c.Section)
                                            .Distinct()
                                            .OrderBy(s => s)
                                            .ToList();
        StateHasChanged();
    }

    private void SelectSection(string section)
    {
        selectedSection = section;
        
        filteredSubjects = allSchoolClasses.Where(c => c.GradeLevel == selectedGrade && 
                                                       c.Section == section && 
                                                       (string.IsNullOrEmpty(selectedStrand) || c.Strand == selectedStrand || selectedStrand == "N/A"))
                                            .OrderBy(c => c.ScheduleStart)
                                            .ToList();
        StateHasChanged();
    }

    private void ResetFilters()
    {
        selectedGrade = null;
        selectedStrand = "";
        selectedSection = "";
        selectedSubject = null;
    }

    private void ResetSectionSelection()
    {
        if (selectedGrade >= 11)
        {
            selectedStrand = "";
        }
        selectedSection = "";
        selectedSubject = null;
    }

    private void OnGradeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int grade))
        {
            SelectGrade(grade);
        }
        else
        {
            ResetFilters();
        }
    }

    private void OnStrandChanged(ChangeEventArgs e)
    {
        SelectStrand(e.Value?.ToString() ?? "");
    }

    private void OnSectionChanged(ChangeEventArgs e)
    {
        SelectSection(e.Value?.ToString() ?? "");
    }

    // Common Logic
    private void SelectSubject(ClassOffering subject)
    {
        selectedSubject = subject;
        recentScans.Clear();
        showFeedback = false;
        _ = EnsureInputFocusLoop();
    }

    private void EndSession()
    {
        selectedSubject = null;
        hiddenInputBuffer = "";
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(hiddenInputBuffer))
        {
            var qrCode = hiddenInputBuffer.Trim();
            hiddenInputBuffer = "";
            await ProcessScan(qrCode);
        }
    }

    private async Task ProcessScan(string qrCode)
    {
        if (isProcessing || selectedSubject == null) return;

        isProcessing = true;
        showFeedback = false;
        StateHasChanged();

        try
        {
            // 20-minute late lockout validation
            var currentTime = DateTime.Now.TimeOfDay;
            var lateThreshold = selectedSubject.ScheduleStart.Add(TimeSpan.FromMinutes(20));
            
            if (currentTime > lateThreshold)
            {
                ShowFeedback(false, "Scan Rejected: Past 20 minutes start time limit.");
                PlayErrorSound();
                AddRecentScan(qrCode, false, "Late Lockout");
                return;
            }

            // Extract User ID if formatted
            string studentId = qrCode;
            if (qrCode.StartsWith("STUDENT:"))
            {
                studentId = qrCode.Substring(8);
            }

            // Core validation logic via HybridQRValidationService 
            // TeacherId param needs to be the actual teacher assigned to that subject offering, NOT necessarily the logged-in User
            string validatorTeacherId = isHeadUser ? selectedSubject.TeacherId : currentUserId;

            var result = await HybridQRValidationService.ValidateQRCodeAsync(studentId, "TimeIn", validatorTeacherId, selectedSubject.ClassOfferingId);
            scannedStudentName = result.StudentName ?? result.StudentData?.FullName ?? "Unknown Student";

            if (result.IsValid)
            {
                ShowFeedback(true, "Attendance Confirmed");
                PlaySuccessSound();
                AddRecentScan(scannedStudentName, true, "Present");
            }
            else
            {
                ShowFeedback(false, result.Message);
                PlayErrorSound();
                AddRecentScan(scannedStudentName, false, "Rejected");
            }
        }
        catch (Exception ex)
        {
            ShowFeedback(false, $"Error: {ex.Message}");
            PlayErrorSound();
        }
        finally
        {
            isProcessing = false;
            // Immediate cursor refocus to allow continuous rapid scanning
            _ = EnsureInputFocus();
            StateHasChanged();
        }
    }

    private void ShowFeedback(bool success, string message)
    {
        feedbackSuccess = success;
        feedbackMessage = message;
        showFeedback = true;
        
        // Hide large feedback after 3 seconds asynchronously
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            showFeedback = false;
            await InvokeAsync(StateHasChanged);
        });
    }

    private void AddRecentScan(string name, bool success, string status)
    {
        recentScans.Insert(0, new ScanRecord
        {
            Name = name,
            Success = success,
            Time = DateTime.Now,
            Status = status
        });

        if (recentScans.Count > 15)
        {
            recentScans = recentScans.Take(15).ToList();
        }
    }

    private async Task EnsureInputFocus()
    {
        if (selectedSubject != null)
        {
            try { await hiddenScannerInput.FocusAsync(); } catch { }
        }
    }

    private async Task EnsureInputFocusLoop()
    {
        // Delay to allow DOM to render the scanner view before focusing
        await Task.Delay(100);
        await EnsureInputFocus();
    }

    private void PlaySuccessSound()
    {
        try 
        { 
            HapticFeedback.Default.Perform(HapticFeedbackType.Click);
        } catch { }
    }

    private void PlayErrorSound()
    {
        try 
        { 
            HapticFeedback.Default.Perform(HapticFeedbackType.LongPress);
        } catch { }
    }

    private string FormatTimeSpan(TimeSpan ts)
    {
        DateTime dt = DateTime.Today.Add(ts);
        return dt.ToString("hh:mm tt");
    }
}



