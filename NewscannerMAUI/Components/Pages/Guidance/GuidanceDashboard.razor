@page "/guidance-dashboard"
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@using Microsoft.JSInterop
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="guidance-container">
    <div class="header-banner">
        <div class="header-content">
            <h1 class="welcome-text">Guidance Counselor Dashboard</h1>
            <p class="subtitle">Monitoring student attendance risk & consecutive absences</p>
            <p style="font-size: 10px; opacity: 0.5;">Debug: User: @currentUser?.UserId | School: @dashboardData?.AllStudents?.FirstOrDefault()?.SchoolId</p>
        </div>
        <div class="header-actions">
            <button class="btn-report" @onclick="GenerateReport" title="Generate PDF Report">
                <i class="fas fa-file-pdf"></i> Report
            </button>
            <button class="btn-search-toggle" @onclick="ToggleSearch">
                <i class="fas fa-search"></i>
            </button>
            <button class="btn-refresh" @onclick="RefreshData" disabled="@isLoading">
                <i class="fas fa-sync-alt @(isLoading ? "fa-spin" : "")"></i>
            </button>
        </div>
    </div>

    <!-- Printable Content Wrapper -->
    <div id="report-content">

    @if (showSearch)
    {
        <div class="search-overlay">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" placeholder="Search students by name or ID..." @bind="searchQuery" @bind:event="oninput" />
                <button class="btn-close-search" @onclick="ToggleSearch"><i class="fas fa-times"></i></button>
            </div>
        </div>
    }

    <!-- Key Metrics -->
    <div class="metrics-grid">
        <div class="metric-card risk">
            <div class="metric-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.FlaggedStudents</span>
                <span class="metric-label">Students at Risk</span>
            </div>
            <div class="metric-trend">
                <span class="text-danger"><i class="fas fa-arrow-up"></i> High priority</span>
            </div>
        </div>
        <div class="metric-card warning">
            <div class="metric-icon">
                <i class="fas fa-door-open"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.NoTimeOutCount</span>
                <span class="metric-label">No TimeOut Today</span>
            </div>
            <div class="metric-trend">
                <span class="text-warning"><i class="fas fa-walking"></i> Cutting class risk</span>
            </div>
        </div>
        <div class="metric-card info">
            <div class="metric-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.TotalStudents</span>
                <span class="metric-label">Total Students</span>
            </div>
        </div>
        <div class="metric-card success">
            <div class="metric-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.GradeLevelsAffected</span>
                <span class="metric-label">Affected Grades</span>
            </div>
        </div>
        <div class="metric-card primary">
            <div class="metric-icon">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.WeeklyAttendanceRate.ToString("F1")%</span>
                <span class="metric-label">Weekly Attendance</span>
            </div>
            <div class="metric-trend">
                <span class="text-success"><i class="fas fa-calendar-week"></i> Last 7 days</span>
            </div>
        </div>
        
        <!-- NEW DYNAMIC PERCENTAGE METRICS -->
        <div class="metric-card success">
            <div class="metric-icon">
                <i class="fas fa-user-check"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.DailyPresenceRate.ToString("F1")%</span>
                <span class="metric-label">Daily Presence</span>
            </div>
            <div class="metric-trend">
                <span class="text-success"><i class="fas fa-caret-up"></i> Live</span>
            </div>
        </div>

        <div class="metric-card warning">
            <div class="metric-icon">
                <i class="fas fa-clipboard-check"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.CaseResolutionRate.ToString("F1")%</span>
                <span class="metric-label">Case Resolution</span>
            </div>
            <div class="metric-trend">
                <span class="text-info"><i class="fas fa-tasks"></i> Efficiency</span>
            </div>
        </div>

        <div class="metric-card info">
            <div class="metric-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div class="metric-data">
                <span class="metric-value">@dashboardData.OnTimeArrivalRate.ToString("F1")%</span>
                <span class="metric-label">On-Time Arrival</span>
            </div>
            <div class="metric-trend">
                <span class="text-success"><i class="fas fa-bolt"></i> Punctuality</span>
            </div>
        </div>
    </div>

    <!-- Attendance Risks -->
    <div class="content-section">
            <div class="filter-groups">
                <div class="filter-group">
                    <span class="filter-group-label">Risk Profile:</span>
                    <div class="filter-pills">
                        <button class="filter-pill @(activeFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All Risks</button>
                        <button class="filter-pill @(activeFilter == "consecutive" ? "active" : "")" @onclick='() => SetFilter("consecutive")'>3+ Straight Absences</button>
                        <button class="filter-pill @(activeFilter == "pending" ? "active" : "")" @onclick='() => SetFilter("pending")'>Pending Cases</button>
                    </div>
                </div>
                <div class="filter-group">
                    <span class="filter-group-label">Timeframe:</span>
                    <div class="filter-pills">
                        <button class="filter-pill @(timeRange == 1 ? "active" : "")" @onclick='() => SetTimeRange(1)'>Today</button>
                        <button class="filter-pill @(timeRange == 7 ? "active" : "")" @onclick='() => SetTimeRange(7)'>Weekly</button>
                        <button class="filter-pill @(timeRange == 30 ? "active" : "")" @onclick='() => SetTimeRange(30)'>Monthly</button>
                    </div>
                </div>
            </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="shimmer-card"></div>
                <div class="shimmer-card"></div>
                <div class="shimmer-card"></div>
            </div>
        }
        else if (!filteredRisks.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-user-check"></i></div>
                <h3>All Clear!</h3>
                <p>No students currently match this risk profile.</p>
            </div>
        }
        else
        {
            <div class="risk-list">
                @foreach (var student in filteredRisks)
                {
                    <div class="risk-card @(student.IsConsecutiveRisk ? "critical" : "")">
                        <div class="status-indicator @student.GuidanceStatus.ToLower()"></div>
                        <div class="risk-card-content">
                            <div class="student-main">
                                <div class="student-avatar">
                                    @(student.FullName.Substring(0, 1))
                                </div>
                                <div class="student-details">
                                    <h3 class="student-name">@student.FullName</h3>
                                    <span class="student-meta">@student.GradeLevel - @student.Section (@student.Strand)</span>
                                </div>
                                <div class="risk-badge">
                                    @if (student.IsConsecutiveRisk)
                                    {
                                        <span class="consecutive-tag"><i class="fas fa-fire"></i> @student.ConsecutiveAbsences STRAIGHT</span>
                                    }
                                    else if (student.IncompleteSessions > 0)
                                    {
                                        <span class="cutting-tag"><i class="fas fa-running"></i> @student.IncompleteSessions CUTTING CLASS?</span>
                                    }
                                    else
                                    {
                                        <span class="absent-tag">@student.AbsentDays TOTAL ABSENCES</span>
                                    }
                                </div>
                            </div>
                            
                            <div class="risk-info-row">
                                <div class="info-item">
                                    <span class="info-label">Subject</span>
                                    <span class="info-value">@student.SubjectName</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Rate</span>
                                    <span class="info-value">@student.AttendanceRate.ToString("F1")%</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Last Absent</span>
                                    <span class="info-value">@student.LastAbsentDate?.ToString("MMM dd")</span>
                                </div>
                            </div>

                            <div class="card-actions">
                                <div class="status-badge-container">
                                    <span class="status-badge @student.GuidanceStatus.ToLower()">Status: @student.GuidanceStatus</span>
                                </div>
                                <div class="btn-group">
                                    @if (student.GuidanceStatus != "Pending")
                                    {
                                        <button class="btn-action pending" @onclick='() => UpdateStatus(student.StudentId, "Pending")'>Mark Pending</button>
                                    }
                                    @if (student.GuidanceStatus != "Resolved")
                                    {
                                        <button class="btn-action resolve" @onclick='() => UpdateStatus(student.StudentId, "Resolved")'>Resolve</button>
                                    }
                                    @if (student.IncompleteSessions > 0)
                                    {
                                        <button class="btn-action aware" @onclick='() => NotifyStudent(student.StudentId, "Cutting Class Awareness")'>
                                            <i class="fas fa-bullhorn"></i> Aware
                                        </button>
                                    }
                                    <button class="btn-action view" @onclick="() => ViewDetails(student.StudentId)">Details</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
    </div> <!-- End report-content -->
</div>

<!-- Details Modal -->
@if (showDetailsModal && selectedStudent != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseDetails">
        <div class="modal-content-custom" @onclick:stopPropagation="true">
            <div class="modal-header-custom">
                <h5 class="modal-title">Attendance Details</h5>
                <button type="button" class="btn-close-custom" @onclick="CloseDetails">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body-custom">
                <div class="student-info-section">
                    <div class="avatar-large">
                        @selectedStudent.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <h4>@selectedStudent.FullName</h4>
                    <p class="grade-section">Grade @selectedStudent.GradeLevel - @selectedStudent.Section</p>
                </div>
                
                <div class="stats-row">
                    <div class="stat-box">
                        <span class="stat-num">@selectedStudent.AbsentDays</span>
                        <span class="stat-label">Absences</span>
                    </div>
                    <div class="stat-box">
                        <span class="stat-num">@selectedStudent.ConsecutiveAbsences</span>
                        <span class="stat-label">Consecutive</span>
                    </div>
                    <div class="stat-box">
                        <span class="stat-num">@selectedStudent.IncompleteSessions</span>
                        <span class="stat-label">Cutting</span>
                    </div>
                </div>

                <div class="details-list">
                    <h6>Absent Dates</h6>
                    @if (!string.IsNullOrEmpty(selectedStudent.AbsentDates))
                    {
                        var dates = selectedStudent.AbsentDates.Split(',').Select(d => d.Trim()).Distinct().OrderByDescending(d => d);
                        <ul class="date-list">
                            @foreach (var d in dates)
                            {
                                <li><i class="fas fa-calendar-day"></i> @(DateTime.TryParse(d, out var pDate) ? pDate.ToString("MMM dd, yyyy") : d)</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No specific dates recorded.</p>
                    }
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-secondary w-100" @onclick="CloseDetails">Close</button>
            </div>
        </div>
    </div>
}

<!-- Hidden Formal Printable Table Report (Captured by html2pdf) -->
<div id="formal-report-container" style="display: none;">
    <div style="width: 1000px; background: white; padding: 40px; color: black; font-family: Arial, sans-serif;">
        <div style="text-align: center; margin-bottom: 30px; border-bottom: 2px solid #ccc; padding-bottom: 20px;">
        <h1 style="margin: 0; font-size: 24px; color: #333;">Guidance Counselor Dashboard</h1>
        <h2 style="margin: 5px 0 0; font-size: 18px; color: #666;">Student Attendance Risk Report</h2>
        <p style="margin: 5px 0 0; font-size: 14px; color: #888;">Generated: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")</p>
    </div>

    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
        <thead>
            <tr style="background-color: #f5f5f5; border-bottom: 2px solid #ddd;">
                <th style="padding: 12px; text-align: left; color: #333;">Student Name</th>
                <th style="padding: 12px; text-align: left; color: #333;">Grade/Sec</th>
                <th style="padding: 12px; text-align: center; color: #333;">Total Absences</th>
                <th style="padding: 12px; text-align: center; color: #333;">Consecutive</th>
                <th style="padding: 12px; text-align: center; color: #333;">Cutting Risk</th>
                <th style="padding: 12px; text-align: left; color: #333;">Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in filteredRisks)
            {
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 12px;"><strong>@student.FullName</strong></td>
                    <td style="padding: 12px;">@student.GradeLevel - @student.Section</td>
                    <td style="padding: 12px; text-align: center;">@(student.AbsentDays > 0 ? student.AbsentDays.ToString() : "-")</td>
                    <td style="padding: 12px; text-align: center;">@(student.ConsecutiveAbsences >= 3 ? student.ConsecutiveAbsences.ToString() + " Straight" : "-")</td>
                    <td style="padding: 12px; text-align: center;">@(student.IncompleteSessions > 0 ? student.IncompleteSessions.ToString() + " Sessions" : "-")</td>
                    <td style="padding: 12px;">
                        @if (student.IsConsecutiveRisk || student.IncompleteSessions > 0)
                        {
                            <span style="color: @(student.GuidanceStatus == "Resolved" ? "green" : (student.GuidanceStatus == "Pending" ? "orange" : "red")); font-weight: bold;">
                                @(string.IsNullOrEmpty(student.GuidanceStatus) || student.GuidanceStatus == "Normal" ? "Needs Action" : student.GuidanceStatus)
                            </span>
                        }
                        else
                        {
                            <span style="color: #4CAF50;">Normal</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div style="margin-top: 40px; font-size: 12px; color: #777; text-align: right;">
        Report extracted from SARDO-TRAKCARE system.
    </div>
    </div>
</div>

@code {
    private GuidanceDashboardData dashboardData = new();
    private bool isLoading = true;
    private bool showSearch = false;
    private string searchQuery = "";
    private string activeFilter = "all";
    private int timeRange = 30;
    private UserInfo? currentUser;
    private bool showDetailsModal = false;
    private AttendanceSummary? selectedStudent = null;

    private List<AttendanceSummary> filteredRisks => dashboardData.StudentsAtRisk
        .Where(s => string.IsNullOrEmpty(searchQuery) || s.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(s => activeFilter == "all" || 
                   (activeFilter == "consecutive" && s.IsConsecutiveRisk) ||
                   (activeFilter == "pending" && s.GuidanceStatus == "Pending"))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser == null || currentUser.UserType != UserType.GuidanceCounselor)
        {
            Navigation.NavigateTo("/");
            return;
        }
        await RefreshData();
    }

    private async Task RefreshData()
    {
        if (currentUser == null) return;
        isLoading = true;
        try
        {
            var data = await Http.GetFromJsonAsync<GuidanceDashboardData>($"{ApiConfig.BaseUrl}api/guidance/dashboard/{currentUser.UserId}?days={timeRange}");
            dashboardData = data ?? new GuidanceDashboardData();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error fetching guidance data: " + ex.Message);
            dashboardData ??= new GuidanceDashboardData();
        }
        finally
        {
        finally
        {
            isLoading = false;
        }
    }

    private async Task SetTimeRange(int days)
    {
        timeRange = days;
        await RefreshData();
    }

    private async Task UpdateStatus(string studentId, string status)
    {
        try
        {
            var response = await Http.PostAsJsonAsync($"{ApiConfig.BaseUrl}api/guidance/update-case-status", new UpdateCaseStatusRequest
            {
                StudentId = studentId,
                Status = status
            });

            if (response.IsSuccessStatusCode)
            {
                await RefreshData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Update error: " + ex.Message);
        }
    }

    private async Task NotifyStudent(string studentId, string type)
    {
        try
        {
            var response = await Http.PostAsJsonAsync($"{ApiConfig.BaseUrl}api/guidance/notify-student", new { StudentId = studentId, Type = type });
            if (response.IsSuccessStatusCode)
            {
                await RefreshData();
                // Optional: Show success toast
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Notify error: " + ex.Message);
        }
    }

    private void ToggleSearch() => showSearch = !showSearch;
    private void SetFilter(string filter) => activeFilter = filter;
    
    private void ViewDetails(string studentId)
    {
        selectedStudent = dashboardData.StudentsAtRisk.FirstOrDefault(s => s.StudentId == studentId);
        if (selectedStudent != null)
        {
            showDetailsModal = true;
        }
    }

    private void CloseDetails()
    {
        showDetailsModal = false;
        selectedStudent = null;
    }

    private async Task GenerateReport()
    {
        try
        {
            var now = DateTime.Now;
            var html = BuildGuidanceReportHtml(now, filteredRisks, dashboardData);
            var filename = "Guidance_Risk_Report_" + now.ToString("yyyyMMdd") + ".html";

#if ANDROID
            var downloadPath = Android.OS.Environment.GetExternalStoragePublicDirectory(Android.OS.Environment.DirectoryDownloads).AbsolutePath;
            var filePath = System.IO.Path.Combine(downloadPath, filename);
            
            int count = 1;
            while (System.IO.File.Exists(filePath))
            {
                var nameOnly = System.IO.Path.GetFileNameWithoutExtension(filename);
                filePath = System.IO.Path.Combine(downloadPath, $"{nameOnly}_{count}.html");
                count++;
            }

            await System.IO.File.WriteAllTextAsync(filePath, html);
            await JSRuntime.InvokeVoidAsync("alert", "Guidance Report Downloaded!\n\nSaved to: Phone/Download/" + System.IO.Path.GetFileName(filePath));
#else
            var cachePath = System.IO.Path.Combine(FileSystem.CacheDirectory, filename);
            await System.IO.File.WriteAllTextAsync(cachePath, html);
            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                Title = "Guidance Risk Report",
                File = new ReadOnlyFile(cachePath, "text/html")
            });
#endif
        }
        catch (Exception ex)
        {
            Console.WriteLine("Guidance Report Error: " + ex.Message);
            await JSRuntime.InvokeVoidAsync("alert", "Download Error: " + ex.Message);
        }
    }

    private static string BuildGuidanceReportHtml(DateTime now, IEnumerable<AttendanceSummary> risks, GuidanceDashboardData data)
    {
        var sb = new System.Text.StringBuilder();
        var rows = new System.Text.StringBuilder();

        foreach (var s in risks)
        {
            var statusColor = s.GuidanceStatus == "Resolved" ? "#16a34a" : (s.GuidanceStatus == "Pending" ? "#d97706" : "#dc2626");
            rows.Append("<tr>");
            rows.Append("<td class='col-name'><b>" + System.Net.WebUtility.HtmlEncode(s.FullName) + "</b><br/><small>" + s.GradeLevel + "-" + s.Section + "</small></td>");
            rows.Append("<td class='col-status' style='text-align:center'><span style='color:" + statusColor + ";font-weight:bold'>" + s.GuidanceStatus + "</span></td>");
            rows.Append("<td class='col-time' style='text-align:center'>" + s.AbsentDays + "</td>");
            rows.Append("<td class='col-time' style='text-align:center'>" + s.ConsecutiveAbsences + "</td>");
            rows.Append("<td class='col-time' style='text-align:center'>" + s.IncompleteSessions + "</td>");
            rows.Append("<td class='col-remarks'>" + (s.LastAbsentDate?.ToString("MMM dd") ?? "-") + "</td>");
            rows.Append("</tr>");
        }

        sb.Append("<!DOCTYPE html><html><head><meta charset='UTF-8'>");
        sb.Append("<style>body{font-family:Arial,sans-serif;padding:30px;color:#334155;background:#f8fafc}");
        sb.Append(".report-container{background:white;padding:40px;border-radius:15px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1)}");
        sb.Append(".header{text-align:center;border-bottom:2px solid #6366f1;padding-bottom:20px;margin-bottom:30px}");
        sb.Append(".header h1{margin:0;color:#1e293b;font-size:24px}.header p{margin:5px 0;color:#64748b;font-size:14px}");
        sb.Append(".metrics-summary{display:grid;grid-template-columns:repeat(4, 1fr);gap:15px;margin-bottom:30px}");
        sb.Append(".summary-item{background:#f1f5f9;padding:15px;border-radius:12px;text-align:center}");
        sb.Append(".summary-value{display:block;font-size:18px;font-weight:bold;color:#1e293b}");
        sb.Append(".summary-label{font-size:11px;color:#64748b;text-transform:uppercase}");
        sb.Append("table{width:100%;border-collapse:collapse;margin-top:20px;table-layout:fixed}");
        sb.Append("th,td{padding:12px;border-bottom:1px solid #e2e8f0;font-size:13px;word-wrap:break-word}");
        sb.Append("th{background:#f8fafc;text-align:left;border-bottom:2px solid #cbd5e1;color:#475569;font-size:12px;font-weight:bold}");
        sb.Append(".col-name{width:30%}.col-status{width:15%}.col-time{width:12%}.col-remarks{width:auto}");
        sb.Append(".footer{font-size:11px;color:#94a3b8;text-align:right;margin-top:40px;border-top:1px solid #e2e8f0;padding-top:15px}</style></head><body>");
        
        sb.Append("<div class='report-container'>");
        sb.Append("<div class='header'><h1>Guidance Counselor Risk Report</h1>");
        sb.Append("<p>Date: " + now.ToString("MMMM dd, yyyy") + " | Generated: " + now.ToString("hh:mm tt") + "</p></div>");
        
        // Add Summary Metrics Section
        sb.Append("<div class='metrics-summary'>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.TotalStudents + "</span><span class='summary-label'>Total Students</span></div>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.FlaggedStudents + "</span><span class='summary-label'>At Risk</span></div>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.WeeklyAttendanceRate.ToString("F1") + "%</span><span class='summary-label'>Attendance</span></div>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.DailyPresenceRate.ToString("F1") + "%</span><span class='summary-label'>Presence</span></div>");
        sb.Append("</div>");
        
        sb.Append("<table><thead><tr><th class='col-name'>Student Name</th><th class='col-status' style='text-align:center'>Status</th>");
        sb.Append("<th class='col-time' style='text-align:center'>Absences</th><th class='col-time' style='text-align:center'>Straight</th>");
        sb.Append("<th class='col-time' style='text-align:center'>Cutting</th><th class='col-remarks'>Last Active</th></tr></thead><tbody>");
        sb.Append(rows);
        sb.Append("</tbody></table>");
        sb.Append("<div class='footer'>Generated by SARDO-TRAKCARE Guidance Portal | System-Generated Report</div>");
        sb.Append("</div></body></html>");
        
        return sb.ToString();
    }
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
