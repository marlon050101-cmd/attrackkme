@page "/guidance-dashboard"
@using AttrackSharedClass.Models
@using NewscannerMAUI.Services
@using Microsoft.JSInterop
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="guidance-container">
    <div class="header-banner">
        <div class="header-content">
            <h1 class="welcome-text">Guidance Counselor Dashboard</h1>
            <p class="subtitle">Monitoring student attendance risk & consecutive absences</p>
        </div>
        <div class="header-actions">
            <button class="btn-report" @onclick="GenerateReport" title="Generate PDF Report">
                <i class="fas fa-file-pdf"></i> Report
            </button>
            <button class="btn-search-toggle" @onclick="ToggleSearch">
                <i class="fas fa-search"></i>
            </button>
            <button class="btn-refresh" @onclick="RefreshData" disabled="@isLoading">
                <i class="fas fa-sync-alt @(isLoading ? "fa-spin" : "")"></i> Refresh
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(apiError))
    {
        <div class="api-error-banner">
            <i class="fas fa-exclamation-circle"></i>
            <strong>Connection Error:</strong> @apiError
            <button @onclick="RefreshData" style="margin-left:12px;background:transparent;border:1px solid rgba(255,255,255,0.5);color:white;border-radius:8px;padding:2px 10px;">Retry</button>
        </div>
    }

    <!-- Printable Content Wrapper -->
    <div id="report-content">

    @if (showSearch)
    {
        <div class="search-overlay">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" placeholder="Search students by name or ID..." @bind="searchQuery" @bind:event="oninput" />
                <button class="btn-close-search" @onclick="ToggleSearch"><i class="fas fa-times"></i></button>
            </div>
        </div>
    }

    <!-- Key Metrics -->
    <!-- Analytics Hub -->
    <div class="analytics-hub">
        <!-- Left: Performance Overview -->
        <div class="analytics-card main-chart-card">
            <div class="card-header-formal">
                <i class="fas fa-chart-pie"></i>
                <span>Attendance Overview</span>
            </div>
            <div class="analytics-content flex-row">
                <div class="chart-container">
                    @{
                        var attendance = dashboardData.WeeklyAttendanceRate;
                        var absence = 100 - attendance;
                        // Simple SVG Pie Chart math: circumference = 2 * PI * R (R=35 => ~220)
                        var strokeDashOffset = 220 - (220 * attendance / 100);
                    }
                    <svg viewBox="0 0 100 100" class="pie-chart-svg">
                        <circle cx="50" cy="50" r="35" class="chart-bg" />
                        <circle cx="50" cy="50" r="35" class="chart-progress" 
                                style="stroke-dashoffset: @strokeDashOffset; stroke: @(attendance > 85 ? "#22c55e" : (attendance > 70 ? "#f59e0b" : "#ef4444"))" />
                        <text x="50" y="55" text-anchor="middle" class="chart-text">@attendance.ToString("F0")%</text>
                    </svg>
                    <div class="chart-legend">
                        <div class="legend-item"><span class="dot present"></span> Present</div>
                        <div class="legend-item"><span class="dot absent"></span> Absent</div>
                    </div>
                </div>
                <div class="quick-stats-list">
                    <div class="q-stat">
                        <span class="q-label">Daily Presence</span>
                        <span class="q-value text-success">@dashboardData.DailyPresenceRate.ToString("F1")%</span>
                    </div>
                    <div class="q-stat">
                        <span class="q-label">Case Resolution</span>
                        <span class="q-value text-primary">@dashboardData.CaseResolutionRate.ToString("F1")%</span>
                    </div>
                    <div class="q-stat">
                        <span class="q-label">On-Time Arrival</span>
                        <span class="q-value text-warning">@dashboardData.OnTimeArrivalRate.ToString("F1")%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Center: Attendance Trends (New Graph) -->
        <div class="analytics-card trend-chart-card">
            <div class="card-header-formal">
                <i class="fas fa-chart-line"></i>
                <span>Attendance Trends</span>
                <span class="trend-subtitle">@(timeRange)-Day Waveform</span>
            </div>
            <div class="analytics-content trend-wrapper">
                @if (dashboardData.DailyTrends != null && dashboardData.DailyTrends.Any())
                {
                    <div class="waveform-container">
                        <svg viewBox="-50 0 1100 250" preserveAspectRatio="none" class="waveform-svg">
                            <defs>
                                <linearGradient id="barGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" style="stop-color:#00f2fe;stop-opacity:1" />
                                    <stop offset="100%" style="stop-color:#4facfe;stop-opacity:1" />
                                </linearGradient>
                                <linearGradient id="reflectGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" style="stop-color:#4facfe;stop-opacity:0.3" />
                                    <stop offset="100%" style="stop-color:#00f2fe;stop-opacity:0.01" />
                                </linearGradient>
                            </defs>
                            
                            @{
                                var trendList = dashboardData.DailyTrends;
                                int barCount = trendList.Count;
                                // Use 1000 units for the actual chart area
                                double barWidth = 1000.0 / Math.Max(barCount, 30);
                                double gap = barWidth * 0.25;
                                double actualWidth = barWidth - gap;
                                // Label skipping logic
                                int skip = barCount > 10 ? (barCount > 20 ? 4 : 2) : 1;
                            }

                            @for (int i = 0; i < trendList.Count; i++)
                            {
                                var day = trendList[i];
                                // Scale height (0-100% presence) to 120 units
                                double height = (day.PresenceRate / 100.0) * 120;
                                double x = i * barWidth;
                                double centerX = x + (actualWidth / 2);
                                
                                <g class="trend-group">
                                    <!-- Main Bar -->
                                    <rect x="@x" y="@(150 - height)" width="@actualWidth" height="@height" 
                                          rx="@(actualWidth/2)" ry="@(actualWidth/2)" fill="url(#barGradient)" class="trend-bar">
                                        <title>@day.Date.ToString("MMM dd"): @day.PresenceRate.ToString("F1")%</title>
                                    </rect>

                                    <!-- Reflection -->
                                    <rect x="@x" y="155" width="@actualWidth" height="@(height * 0.4)" 
                                          rx="@(actualWidth/2)" ry="@(actualWidth/2)" fill="url(#reflectGradient)" opacity="0.4" />

                                    <!-- Labels -->
                                    @if (i % skip == 0)
                                    {
                                        @((MarkupString)$"<text x='{centerX}' y='{(145 - height)}' text-anchor='middle' class='trend-label-pct'>{day.PresenceRate:F0}%</text>")
                                        @((MarkupString)$"<text x='{centerX}' y='195' text-anchor='middle' class='trend-label-day'>{day.DayName}</text>")
                                        @((MarkupString)$"<text x='{centerX}' y='215' text-anchor='middle' class='trend-label-date'>{day.Date:dd}</text>")
                                    }
                                </g>
                            }
                        </svg>
                    </div>
                }
                else
                {
                    <div class="empty-trend">
                        <i class="fas fa-chart-bar"></i>
                        <p>No trend data available for this timeframe</p>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Actionable Alerts -->
        <div class="alerts-column">
            <div class="analytics-card alert-card critical">
                <div class="alert-icon-wrap">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div class="alert-info">
                    <span class="alert-count">@dashboardData.FlaggedStudents</span>
                    <span class="alert-label">Risk Profile Flagged</span>
                    <span class="alert-desc">Students needing immediate guidance intervention</span>
                </div>
                <div class="alert-action">
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>

            <div class="analytics-card alert-card warning">
                <div class="alert-icon-wrap">
                    <i class="fas fa-walking"></i>
                </div>
                <div class="alert-info">
                    <span class="alert-count">@dashboardData.NoTimeOutCount</span>
                    <span class="alert-label">Potential Cutting</span>
                    <span class="alert-desc">Incomplete sessions detected in real-time</span>
                </div>
                <div class="alert-action">
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>
            
            <div class="secondary-metrics-row">
                <div class="mini-card">
                    <i class="fas fa-users"></i>
                    <div class="mini-data">
                        <span class="mini-val">@dashboardData.TotalStudents</span>
                        <span class="mini-lbl">Active Students</span>
                    </div>
                </div>
                <div class="mini-card">
                    <i class="fas fa-graduation-cap"></i>
                    <div class="mini-data">
                        <span class="mini-val">@dashboardData.GradeLevelsAffected</span>
                        <span class="mini-lbl">Affected Grades</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Attendance Risks -->
    <div class="content-section">
            <div class="filter-groups">
                <div class="filter-group">
                    <label class="filter-label"><i class="fas fa-filter"></i> Risk Profile</label>
                    <select class="custom-select" @onchange='(e) => SetFilter(e.Value?.ToString() ?? "all")'>
                        <option value="all" selected="@(activeFilter == "all")">All Risks</option>
                        <option value="consecutive" selected="@(activeFilter == "consecutive")">3+ Straight Absences</option>
                        <option value="summoned" selected="@(activeFilter == "summoned")">Summoned</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label class="filter-label"><i class="fas fa-calendar-alt"></i> Timeframe</label>
                    <select class="custom-select" @onchange='(e) => SetTimeRange(int.Parse(e.Value?.ToString() ?? "30"))'>
                        <option value="1" selected="@(timeRange == 1)">Today</option>
                        <option value="7" selected="@(timeRange == 7)">Weekly (Last 7 Days)</option>
                        <option value="30" selected="@(timeRange == 30)">Monthly (Last 30 Days)</option>
                    </select>
                </div>
            </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="shimmer-card"></div>
                <div class="shimmer-card"></div>
                <div class="shimmer-card"></div>
            </div>
        }
        else if (!filteredRisks.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-user-check"></i></div>
                <h3>All Clear!</h3>
                <p>No students currently match this risk profile.</p>
            </div>
        }
        else
        {
            <div class="table-responsive formal-table-container">
                <table class="formal-table">
                    <thead>
                        <tr>
                            <th>Student Information</th>
                            <th>Risk Indicator</th>
                            <th>Subject / Scope</th>
                            <th class="text-center">Rate</th>
                            <th class="text-center">Last Incident/Absent</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in filteredRisks)
                        {
                            <tr class="@(student.IsConsecutiveRisk ? "row-critical" : "")">
                                <td data-label="Student">
                                    <div class="student-info-cell">
                                        <div class="student-avatar-small">@(student.FullName.Substring(0, 1))</div>
                                        <div>
                                            <div class="student-name-small">@student.FullName</div>
                                            <div class="student-meta-small">Grade @student.GradeLevel - @student.Section</div>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Risk">
                                    @if (student.IsConsecutiveRisk)
                                    {
                                        <span class="badge badge-danger"><i class="fas fa-fire"></i> @student.ConsecutiveAbsences STRAIGHT</span>
                                    }
                                    else if (student.IncompleteSessions > 0)
                                    {
                                        <span class="badge badge-purple"><i class="fas fa-running"></i> CUTTING CLASS?</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">@student.AbsentDays TOTAL ABSENCES</span>
                                    }
                                </td>
                                <td data-label="Subject"><span class="subject-text">@student.SubjectName</span></td>
                                <td data-label="Rate" class="text-center"><span class="rate-text">@student.AttendanceRate.ToString("F1")%</span></td>
                                <td data-label="Last Absent" class="text-center"><span class="date-text">@(student.LastAbsentDate?.ToString("MMM dd, yyyy") ?? "—")</span></td>
                                <td data-label="Status" class="text-center">
                                    <span class="status-pill @student.GuidanceStatus.ToLower()">@student.GuidanceStatus</span>
                                </td>
                                <td data-label="Actions" class="text-center">
                                    <div class="action-buttons-cell">
                                        @if (student.GuidanceStatus != "Summoned")
                                        {
                                            bool isSummoning = processingIds.Contains(student.StudentId + "_summon");
                                            <button class="btn-icon circle summoned" title="Summon to Guidance" 
                                                    @onclick='() => ProcessSummon(student.StudentId, student.SubjectName)'
                                                    disabled="@isSummoning">
                                                <i class="fas @(isSummoning ? "fa-spinner fa-spin" : "fa-bullhorn")"></i>
                                            </button>
                                        }
                                        @if (student.GuidanceStatus != "Resolved")
                                        {
                                            bool isResolving = processingIds.Contains(student.StudentId + "_resolve");
                                            <button class="btn-icon circle resolve" title="Resolve" 
                                                    @onclick='() => UpdateStatus(student.StudentId, "Resolved")'
                                                    disabled="@isResolving">
                                                <i class="fas @(isResolving ? "fa-spinner fa-spin" : "fa-check")"></i>
                                            </button>
                                        }
                                        <button class="btn-icon circle view" title="Details" @onclick="() => ViewDetails(student.StudentId)">
                                            <i class="fas fa-external-link-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    </div> <!-- End report-content -->
</div>

<!-- Details Modal -->
@if (showDetailsModal && selectedStudent != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseDetails">
        <div class="modal-content-custom animated-modal" @onclick:stopPropagation="true">
            <div class="modal-header-custom">
                <div class="modal-title-group">
                    <h5 class="modal-title text-primary">Student Risk Profile</h5>
                    <span class="modal-subtitle">Detailed attendance analysis</span>
                </div>
                <button type="button" class="btn-close-custom" @onclick="CloseDetails">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body-custom">
                <!-- Profile Card -->
                <div class="modal-profile-card">
                    <div class="avatar-container">
                        <div class="avatar-large">
                            @selectedStudent.FullName.Substring(0, 1).ToUpper()
                        </div>
                        <div class="risk-indicator-dot @(selectedStudent.IsConsecutiveRisk ? "critical" : "warning")"></div>
                    </div>
                    <div class="profile-text">
                        <h4 class="student-name-modal">@selectedStudent.FullName</h4>
                        <p class="grade-section-modal">Grade @selectedStudent.GradeLevel - @selectedStudent.Section</p>
                        <div class="modal-status-badge @selectedStudent.GuidanceStatus.ToLower()">
                            <i class="fas fa-shield-alt"></i> @selectedStudent.GuidanceStatus
                        </div>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="modal-stats-grid">
                    <div class="modal-stat-card border-left-danger">
                        <div class="stat-icon"><i class="fas fa-calendar-times"></i></div>
                        <div class="stat-content">
                            <span class="stat-label-modal">Total Absences</span>
                            <span class="stat-value-modal">@selectedStudent.AbsentDays</span>
                        </div>
                    </div>
                    <div class="modal-stat-card border-left-warning">
                        <div class="stat-icon"><i class="fas fa-fire-alt"></i></div>
                        <div class="stat-content">
                            <span class="stat-label-modal">Consecutive</span>
                            <span class="stat-value-modal">@selectedStudent.ConsecutiveAbsences</span>
                        </div>
                    </div>
                    <div class="modal-stat-card border-left-purple">
                        <div class="stat-icon"><i class="fas fa-running"></i></div>
                        <div class="stat-content">
                            <span class="stat-label-modal">Cutting Class</span>
                            <span class="stat-value-modal">@selectedStudent.IncompleteSessions</span>
                        </div>
                    </div>
                    <div class="modal-stat-card border-left-primary">
                        <div class="stat-icon"><i class="fas fa-percentage"></i></div>
                        <div class="stat-content">
                            <span class="stat-label-modal">Attendance Rate</span>
                            <span class="stat-value-modal">@selectedStudent.AttendanceRate.ToString("F1")%</span>
                        </div>
                    </div>
                </div>

                <!-- Date History Section -->
                <div class="modal-history-section">
                    <div class="section-divider">
                        <span><i class="fas fa-history"></i> Incident History</span>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(selectedStudent.AbsentDates))
                    {
                        var dates = selectedStudent.AbsentDates.Split(',').Select(d => d.Trim()).Distinct().OrderByDescending(d => d);
                        <div class="date-scroll-container">
                            @foreach (var d in dates)
                            {
                                <div class="date-item-card">
                                    <div class="date-icon"><i class="fas fa-calendar-day"></i></div>
                                    <div class="date-info">
                                        <span class="date-text-modal">@(DateTime.TryParse(d, out var pDate) ? pDate.ToString("MMMM dd, yyyy") : d)</span>
                                        <span class="date-label-modal">Full Day Absence</span>
                                    </div>
                                    <span class="date-tag">Unexcused</span>
                                </div>
                            }
                        </div>
                    }
                    else if (selectedStudent.IncompleteSessions > 0)
                    {
                        <div class="date-item-card warning">
                            <div class="date-icon"><i class="fas fa-clock"></i></div>
                            <div class="date-info">
                                <span class="date-text-modal">Last Instance: @(selectedStudent.LastAbsentDate?.ToString("MMM dd, yyyy") ?? "Today")</span>
                                <span class="date-label-modal">Missing Time-Out Detected</span>
                            </div>
                            <span class="date-tag-purple">Cutting Risk</span>
                        </div>
                    }
                    else
                    {
                        <div class="empty-modal-state">
                            <i class="fas fa-check-circle"></i>
                            <p>No recorded incidents for this timeframe.</p>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-modal-close" @onclick="CloseDetails">Done</button>
            </div>
        </div>
    </div>
}

<!-- Hidden Formal Printable Table Report (Captured by html2pdf) -->
<div id="formal-report-container" style="display: none;">
    <div style="width: 1000px; background: white; padding: 40px; color: black; font-family: Arial, sans-serif;">
        <div style="text-align: center; margin-bottom: 30px; border-bottom: 2px solid #ccc; padding-bottom: 20px;">
        <h1 style="margin: 0; font-size: 24px; color: #333;">Guidance Counselor Dashboard</h1>
        <h2 style="margin: 5px 0 0; font-size: 18px; color: #666;">Student Attendance Risk Report</h2>
        <p style="margin: 5px 0 0; font-size: 14px; color: #888;">Generated: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")</p>
    </div>

    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
        <thead>
            <tr style="background-color: #f5f5f5; border-bottom: 2px solid #ddd;">
                <th style="padding: 12px; text-align: left; color: #333;">Student Name</th>
                <th style="padding: 12px; text-align: left; color: #333;">Grade/Sec</th>
                <th style="padding: 12px; text-align: center; color: #333;">Total Absences</th>
                <th style="padding: 12px; text-align: center; color: #333;">Consecutive</th>
                <th style="padding: 12px; text-align: center; color: #333;">Cutting Risk</th>
                <th style="padding: 12px; text-align: left; color: #333;">Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in filteredRisks)
            {
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 12px;"><strong>@student.FullName</strong></td>
                    <td style="padding: 12px;">@student.GradeLevel - @student.Section</td>
                    <td style="padding: 12px; text-align: center;">@(student.AbsentDays > 0 ? student.AbsentDays.ToString() : "-")</td>
                    <td style="padding: 12px; text-align: center;">@(student.ConsecutiveAbsences >= 3 ? student.ConsecutiveAbsences.ToString() + " Straight" : "-")</td>
                    <td style="padding: 12px; text-align: center;">@(student.IncompleteSessions > 0 ? student.IncompleteSessions.ToString() + " Sessions" : "-")</td>
                    <td style="padding: 12px;">
                        @if (student.IsConsecutiveRisk || student.IncompleteSessions > 0)
                        {
                            <span style="color: @(student.GuidanceStatus == "Resolved" ? "green" : (student.GuidanceStatus == "Pending" ? "orange" : "red")); font-weight: bold;">
                                @(string.IsNullOrEmpty(student.GuidanceStatus) || student.GuidanceStatus == "Normal" ? "Needs Action" : student.GuidanceStatus)
                            </span>
                        }
                        else
                        {
                            <span style="color: #4CAF50;">Normal</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div style="margin-top: 40px; font-size: 12px; color: #777; text-align: right;">
        Report extracted from SARDO-TRAKCARE system.
    </div>
    </div>
</div>

@code {
    private GuidanceDashboardData dashboardData = new();
    private bool isLoading = true;
    private bool showSearch = false;
    private string searchQuery = "";
    private string activeFilter = "all";
    private int timeRange = 30;
    private UserInfo? currentUser;
    private bool showDetailsModal = false;
    private AttendanceSummary? selectedStudent = null;
    private HashSet<string> processingIds = new();

    private List<AttendanceSummary> filteredRisks => dashboardData.StudentsAtRisk
        .Where(s => string.IsNullOrEmpty(searchQuery) || s.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(s => activeFilter == "all" || 
                   (activeFilter == "consecutive" && s.IsConsecutiveRisk) ||
                   (activeFilter == "pending" && s.GuidanceStatus == "Pending"))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser == null || currentUser.UserType != UserType.GuidanceCounselor)
        {
            Navigation.NavigateTo("/");
            return;
        }
        await RefreshData();
    }

    private string? apiError = null;

    private async Task RefreshData()
    {
        if (currentUser == null) return;
        isLoading = true;
        apiError = null;
        try
        {
            var response = await Http.GetAsync($"{ApiConfig.BaseUrl}api/guidance/dashboard/{currentUser.UserId}?days={timeRange}");
            
            if (response.IsSuccessStatusCode)
            {
                dashboardData = await response.Content.ReadFromJsonAsync<GuidanceDashboardData>() ?? new GuidanceDashboardData();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                try 
                {
                    using var jsonDoc = System.Text.Json.JsonDocument.Parse(errorContent);
                    if (jsonDoc.RootElement.TryGetProperty("message", out var msg))
                    {
                        apiError = msg.GetString();
                    }
                    else 
                    {
                        apiError = $"Server Error ({response.StatusCode}): {errorContent}";
                    }
                }
                catch 
                {
                    apiError = $"Server Error ({response.StatusCode}): {errorContent}";
                }
                dashboardData = new GuidanceDashboardData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error fetching guidance data: " + ex.Message);
            apiError = ex.Message;
            dashboardData = new GuidanceDashboardData();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SetTimeRange(int days)
    {
        timeRange = days;
        await RefreshData();
    }

    private async Task ProcessSummon(string studentId, string riskSource)
    {
        // NotifyStudent already calls UpdateCaseStatusAsync internally to set status to 'Summoned'
        // and logs the notification in notes. Calling both would cause duplicate updates.
        await NotifyStudent(studentId, $"Guidance Summon: {riskSource}");
    }

    private async Task UpdateStatus(string studentId, string status)
    {
        var procId = studentId + "_resolve";
        if (processingIds.Contains(procId)) return;
        
        try
        {
            processingIds.Add(procId);
            var response = await Http.PostAsJsonAsync($"{ApiConfig.BaseUrl}api/guidance/update-case-status", new UpdateCaseStatusRequest
            {
                StudentId = studentId,
                Status = status
            });

            if (response.IsSuccessStatusCode)
            {
                await RefreshData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Update error: " + ex.Message);
        }
        finally
        {
            processingIds.Remove(procId);
        }
    }

    private async Task NotifyStudent(string studentId, string type)
    {
        var procId = studentId + "_summon";
        if (processingIds.Contains(procId)) return;

        try
        {
            processingIds.Add(procId);
            var response = await Http.PostAsJsonAsync($"{ApiConfig.BaseUrl}api/guidance/notify-student", new { StudentId = studentId, Type = type });
            if (response.IsSuccessStatusCode)
            {
                await RefreshData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Notify error: " + ex.Message);
        }
        finally
        {
            processingIds.Remove(procId);
        }
    }

    private void ToggleSearch() => showSearch = !showSearch;
    private void SetFilter(string filter) => activeFilter = filter;

    private async Task TestDatabaseConnection()
    {
        if (currentUser == null) return;
        try
        {
            var userId = currentUser.UserId;
            var response = await Http.GetAsync($"{ApiConfig.BaseUrl}api/guidance/test/{userId}");
            var result = await response.Content.ReadAsStringAsync();
            await JSRuntime.InvokeVoidAsync("alert", $"Diagnostic Result:\n{result}");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Test failed: {ex.Message}");
        }
    }

    private void ViewDetails(string studentId)
    {
        selectedStudent = dashboardData.StudentsAtRisk.FirstOrDefault(s => s.StudentId == studentId);
        if (selectedStudent != null)
        {
            showDetailsModal = true;
        }
    }

    private void CloseDetails()
    {
        showDetailsModal = false;
        selectedStudent = null;
    }

    private async Task GenerateReport()
    {
        try
        {
            var now = DateTime.Now;
            var html = BuildGuidanceReportHtml(now, filteredRisks, dashboardData);
            var filename = "Guidance_Risk_Report_" + now.ToString("yyyyMMdd") + ".html";

#if ANDROID
            var downloadPath = Android.OS.Environment.GetExternalStoragePublicDirectory(Android.OS.Environment.DirectoryDownloads).AbsolutePath;
            var filePath = System.IO.Path.Combine(downloadPath, filename);
            
            int count = 1;
            while (System.IO.File.Exists(filePath))
            {
                var nameOnly = System.IO.Path.GetFileNameWithoutExtension(filename);
                filePath = System.IO.Path.Combine(downloadPath, $"{nameOnly}_{count}.html");
                count++;
            }

            await System.IO.File.WriteAllTextAsync(filePath, html);
            await JSRuntime.InvokeVoidAsync("alert", "Guidance Report Downloaded!\n\nSaved to: Phone/Download/" + System.IO.Path.GetFileName(filePath));
#else
            var cachePath = System.IO.Path.Combine(FileSystem.CacheDirectory, filename);
            await System.IO.File.WriteAllTextAsync(cachePath, html);
            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                Title = "Guidance Risk Report",
                File = new ReadOnlyFile(cachePath, "text/html")
            });
#endif
        }
        catch (Exception ex)
        {
            Console.WriteLine("Guidance Report Error: " + ex.Message);
            await JSRuntime.InvokeVoidAsync("alert", "Download Error: " + ex.Message);
        }
    }

    private static string BuildGuidanceReportHtml(DateTime now, IEnumerable<AttendanceSummary> risks, GuidanceDashboardData data)
    {
        var sb = new System.Text.StringBuilder();
        var rows = new System.Text.StringBuilder();

        foreach (var s in risks)
        {
            var statusColor = s.GuidanceStatus == "Resolved" ? "#16a34a" : (s.GuidanceStatus == "Pending" ? "#d97706" : "#dc2626");
            rows.Append("<tr>");
            rows.Append("<td class='col-name'><b>" + System.Net.WebUtility.HtmlEncode(s.FullName) + "</b><br/><small>" + s.GradeLevel + "-" + s.Section + "</small></td>");
            rows.Append("<td class='col-status' style='text-align:center'><span style='color:" + statusColor + ";font-weight:bold'>" + s.GuidanceStatus + "</span></td>");
            rows.Append("<td class='col-time' style='text-align:center'>" + s.AbsentDays + "</td>");
            rows.Append("<td class='col-time' style='text-align:center'>" + s.ConsecutiveAbsences + "</td>");
            rows.Append("<td class='col-time' style='text-align:center'>" + s.IncompleteSessions + "</td>");
            rows.Append("<td class='col-remarks'>" + (s.LastAbsentDate?.ToString("MMM dd") ?? "-") + "</td>");
            rows.Append("</tr>");
        }

        sb.Append("<!DOCTYPE html><html><head><meta charset='UTF-8'>");
        sb.Append("<style>body{font-family:Arial,sans-serif;padding:30px;color:#334155;background:#f8fafc}");
        sb.Append(".report-container{background:white;padding:40px;border-radius:15px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1)}");
        sb.Append(".header{text-align:center;border-bottom:2px solid #6366f1;padding-bottom:20px;margin-bottom:30px}");
        sb.Append(".header h1{margin:0;color:#1e293b;font-size:24px}.header p{margin:5px 0;color:#64748b;font-size:14px}");
        sb.Append(".metrics-summary{display:grid;grid-template-columns:repeat(4, 1fr);gap:15px;margin-bottom:30px}");
        sb.Append(".summary-item{background:#f1f5f9;padding:15px;border-radius:12px;text-align:center}");
        sb.Append(".summary-value{display:block;font-size:18px;font-weight:bold;color:#1e293b}");
        sb.Append(".summary-label{font-size:11px;color:#64748b;text-transform:uppercase}");
        sb.Append("table{width:100%;border-collapse:collapse;margin-top:20px;table-layout:fixed}");
        sb.Append("th,td{padding:12px;border-bottom:1px solid #e2e8f0;font-size:13px;word-wrap:break-word}");
        sb.Append("th{background:#f8fafc;text-align:left;border-bottom:2px solid #cbd5e1;color:#475569;font-size:12px;font-weight:bold}");
        sb.Append(".col-name{width:30%}.col-status{width:15%}.col-time{width:12%}.col-remarks{width:auto}");
        sb.Append(".footer{font-size:11px;color:#94a3b8;text-align:right;margin-top:40px;border-top:1px solid #e2e8f0;padding-top:15px}</style></head><body>");
        
        sb.Append("<div class='report-container'>");
        sb.Append("<div class='header'><h1>Guidance Counselor Risk Report</h1>");
        sb.Append("<p>Date: " + now.ToString("MMMM dd, yyyy") + " | Generated: " + now.ToString("hh:mm tt") + "</p></div>");
        
        // Add Summary Metrics Section
        sb.Append("<div class='metrics-summary'>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.TotalStudents + "</span><span class='summary-label'>Total Students</span></div>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.FlaggedStudents + "</span><span class='summary-label'>At Risk</span></div>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.WeeklyAttendanceRate.ToString("F1") + "%</span><span class='summary-label'>Attendance</span></div>");
        sb.Append("<div class='summary-item'><span class='summary-value'>" + data.DailyPresenceRate.ToString("F1") + "%</span><span class='summary-label'>Presence</span></div>");
        sb.Append("</div>");
        
        sb.Append("<table><thead><tr><th class='col-name'>Student Name</th><th class='col-status' style='text-align:center'>Status</th>");
        sb.Append("<th class='col-time' style='text-align:center'>Absences</th><th class='col-time' style='text-align:center'>Straight</th>");
        sb.Append("<th class='col-time' style='text-align:center'>Cutting</th><th class='col-remarks'>Last Active</th></tr></thead><tbody>");
        sb.Append(rows);
        sb.Append("</tbody></table>");
        sb.Append("<div class='footer'>Generated by SARDO-TRAKCARE Guidance Portal | System-Generated Report</div>");
        sb.Append("</div></body></html>");
        
        return sb.ToString();
    }
}

